---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SitemapLinkCard from '../components/sitemap/SitemapLinkCard.astro';
import SitemapTestMethodology from '../components/sitemap/SitemapTestMethodology.astro';
import SitemapResourcesLegal from '../components/sitemap/SitemapResourcesLegal.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import { buildFullHtmlSitemapPage } from '../lib/sitemap';

const page = buildFullHtmlSitemapPage();
---

<BaseLayout title="HTML Sitemap — AI Girlfriend Expert" description="Complete index of all reviews, roundups, guides, testing methodology, authors, resources, and legal pages.">
  <Header />
  <main class="sitemap-page">
    <div class="section-container px-4 md:px-8 py-10 md:py-14">
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/' },
          { label: 'HTML Sitemap' },
        ]}
      />

      <header class="sitemap-page__header">
        <h1 class="sitemap-page__title">HTML Sitemap</h1>
        <p class="sitemap-page__intro">
          Complete index of every published page. Counts and links update automatically when content changes.
        </p>
      </header>

      <div class="sitemap-layout">
        <div class="sitemap-row sitemap-row--top">
          <SitemapLinkCard
            title="Reviews"
            count={page.reviews.length}
            icon="star"
            tone="amber"
            links={page.reviews}
          />
          <SitemapLinkCard
            title="Roundups"
            count={page.roundups.length}
            icon="checklist"
            tone="lime"
            links={page.roundups}
          />
          <SitemapLinkCard
            title="Guides"
            count={page.guides.length}
            icon="menu_book"
            tone="green"
            links={page.guides}
          />
          <SitemapLinkCard
            title="Authors"
            count={page.authors.length}
            icon="person"
            tone="amber"
            links={page.authors}
          />
        </div>

        <div class="sitemap-row sitemap-row--bottom">
          <SitemapTestMethodology count={page.testCount} />
          <SitemapResourcesLegal
            count={page.resourcesLegalCount}
            resources={page.resources}
            legal={page.legal}
          />
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  @import '../styles/sitemap.css';
</style>
