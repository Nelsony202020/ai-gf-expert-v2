---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BrandIcon from '../components/ui/BrandIcon.astro';
import { brandIcons } from '../lib/brand-icons';
import { products } from '../data/products';

const sections = [
  {
    id: 'reviews',
    title: 'Reviews',
    count: products.length,
    icon: 'star',
    tone: 'amber',
    links: products.slice(0, 5).map((p) => ({ label: `${p.name} Review`, href: `/reviews/${p.slug}` })),
    viewAll: { label: 'View all reviews', href: '#' },
  },
  {
    id: 'roundups',
    title: 'Roundups',
    count: 8,
    icon: 'checklist',
    tone: 'lime',
    links: [
      { label: 'Best AI Girlfriend Apps', href: '#' },
      { label: 'Best Free AI Companions', href: '#' },
      { label: 'Best NSFW AI Chat Apps', href: '#' },
      { label: 'Best AI Character Creators', href: '#' },
      { label: 'Best AI Roleplay Apps', href: '#' },
    ],
    viewAll: { label: 'View all roundups', href: '#' },
  },
  {
    id: 'guides',
    title: 'Guides',
    count: 6,
    icon: 'menu_book',
    tone: 'green',
    links: [
      { label: 'AI Girlfriend Buying Guide', href: '#' },
      { label: 'How AI Companion Chat Works', href: '#' },
      { label: 'Privacy & Safety Checklist', href: '#' },
      { label: 'Understanding AI Image Gen', href: '#' },
      { label: 'Voice & Video Features Explained', href: '#' },
    ],
    viewAll: { label: 'View all guides', href: '#' },
  },
  {
    id: 'authors',
    title: 'Authors',
    count: 1,
    icon: 'person',
    tone: 'amber',
    links: [{ label: 'Herman Carter', href: '/author/herman-carter' }],
    viewAll: { label: 'View all authors', href: '/author/herman-carter' },
  },
  {
    id: 'resources',
    title: 'Resources',
    count: 7,
    icon: 'folder',
    tone: 'lime',
    links: [
      { label: 'Our Methodology', href: '#' },
      { label: 'How We Test', href: '#' },
      { label: 'Scoring System', href: '#' },
      { label: 'FAQ', href: '/faq' },
      { label: 'Affiliate Disclosure', href: '/legal/affiliate-disclosure' },
    ],
    viewAll: { label: 'View all resources', href: '/faq' },
  },
  {
    id: 'legal',
    title: 'Legal & Info',
    count: 6,
    icon: 'shield',
    tone: 'lime',
    links: [
      { label: 'Privacy Policy', href: '/legal/privacy' },
      { label: 'Terms of Service', href: '/legal/terms' },
      { label: 'Copyright Policy', href: '/legal/copyright' },
      { label: 'Disclaimer', href: '/legal/disclaimer' },
      { label: 'Affiliate Disclosure', href: '/legal/affiliate-disclosure' },
    ],
    viewAll: { label: 'View all legal & info', href: '/legal/privacy' },
  },
  {
    id: 'company',
    title: 'Company',
    count: 3,
    icon: 'apartment',
    tone: 'green',
    links: [
      { label: 'About Us', href: '#' },
      { label: 'Contact', href: '/contact' },
      { label: 'HTML Sitemap', href: '/sitemap' },
    ],
    viewAll: null,
  },
];
---

<BaseLayout title="HTML Sitemap — AI Girlfriend Expert" description="Browse all reviews, roundups, guides, authors, resources, and company pages.">
  <Header />
  <main class="sitemap-page">
    <div class="section-container px-4 md:px-8 py-10 md:py-14">
      <nav class="text-sm text-tertiary mb-6 flex items-center gap-1.5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-on-surface-variant font-semibold">HTML Sitemap</span>
      </nav>

      <div class="max-w-3xl mb-10">
        <h1 class="text-3xl md:text-4xl font-black text-on-surface mb-3">HTML Sitemap</h1>
        <p class="text-base text-on-surface-variant leading-relaxed">
          Browse all reviews, roundups, guides, authors, resources, and company pages.
        </p>
      </div>

      <div class="sitemap-grid">
        {
          sections.map((section) => (
            <section class="sitemap-card">
              <div class="sitemap-card__head">
                <span class={`sitemap-card__icon sitemap-card__icon--${section.tone}`}>
                  <span class="material-symbols-outlined">{section.icon}</span>
                </span>
                <h2 class="sitemap-card__title">{section.title} ({section.count})</h2>
              </div>
              <ul class="sitemap-card__links">
                {section.links.map((link) => (
                  <li>
                    <a href={link.href} class="sitemap-card__link">
                      <span>{link.label}</span>
                      <span class="material-symbols-outlined sitemap-card__arrow">chevron_right</span>
                    </a>
                  </li>
                ))}
              </ul>
              {
                section.viewAll && (
                  <a href={section.viewAll.href} class="sitemap-card__view-all">
                    <span class="link-text">{section.viewAll.label}</span>
                    <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                  </a>
                )
              }
            </section>
          ))
        }

        <section class="sitemap-card sitemap-card--search">
          <BrandIcon
            src={brandIcons.searching.dark}
            srcLight={brandIcons.searching.light}
            width={80}
            height={80}
            class="sitemap-card__hero-icon"
          />
          <h2 class="sitemap-card__title text-center">Looking for a specific page?</h2>
          <p class="text-sm text-on-surface-variant text-center leading-relaxed">
            Use the search bar in the header to quickly find what you need.
          </p>
        </section>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .sitemap-page {
    background: var(--color-background);
    min-height: 60vh;
  }

  .sitemap-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  @media (max-width: 768px) {
    .sitemap-grid {
      grid-template-columns: 1fr;
    }
  }

  .sitemap-card {
    background: #fff;
    border: 1px solid var(--color-surface-variant);
    border-radius: 14px;
    padding: 18px 18px 16px;
    box-shadow: 0 1px 3px rgb(0 0 0 / 4%);
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .sitemap-card__head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .sitemap-card__icon {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sitemap-card__icon .material-symbols-outlined {
    font-size: 18px;
  }

  .sitemap-card__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-on-surface);
  }

  .sitemap-card__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .sitemap-card__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 8px 4px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .sitemap-card__link:hover {
    background: rgb(219 39 119 / 6%);
  }

  .sitemap-card__arrow {
    font-size: 16px;
    color: var(--color-tertiary);
  }

  .sitemap-card__view-all {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 10px;
    font-size: 12px;
    font-weight: 800;
    color: var(--color-accent);
    text-decoration: none;
  }

  .sitemap-card--search {
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 10px;
    padding-top: 28px;
    padding-bottom: 28px;
  }

  .sitemap-card__hero-icon {
    width: 80px;
    height: 80px;
    margin-bottom: 6px;
  }
</style>

<style is:global>
  .sitemap-card__icon--amber {
    background: rgb(245 158 11 / 12%);
    color: #d97706;
  }

  .sitemap-card__icon--lime {
    background: rgb(218 246 108 / 35%);
    color: #4d7c0f;
  }

  .sitemap-card__icon--green {
    background: rgb(34 197 94 / 12%);
    color: #15803d;
  }

  [data-theme='dark'] .sitemap-card {
    background: #1a1f18;
    border-color: #2a3328;
  }

  [data-theme='dark'] .sitemap-card__title {
    color: #ececec;
  }

  [data-theme='dark'] .sitemap-card__icon--amber {
    background: rgb(251 191 36 / 14%);
    color: #fbbf24;
  }

  [data-theme='dark'] .sitemap-card__icon--lime {
    background: rgb(218 246 108 / 14%);
    color: #daf66c;
  }

  [data-theme='dark'] .sitemap-card__icon--green {
    background: rgb(134 239 172 / 12%);
    color: #86efac;
  }

  [data-theme='dark'] .sitemap-card__icon .material-symbols-outlined {
    font-variation-settings:
      'FILL' 1,
      'wght' 500,
      'GRAD' 0,
      'opsz' 24;
  }

  [data-theme='dark'] .sitemap-card__arrow {
    color: #9cab96;
  }

  [data-theme='dark'] .sitemap-card__link:hover {
    background: rgb(219 39 119 / 10%);
  }
</style>
