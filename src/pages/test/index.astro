---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TestBreadcrumbs from '../../components/test/TestBreadcrumbs.astro';
import TestHubCategoryCards from '../../components/test/TestHubCategoryCards.astro';
import TestHubFrameworkAccordion from '../../components/test/TestHubFrameworkAccordion.astro';
import TestHubHierarchyPipeline from '../../components/test/TestHubHierarchyPipeline.astro';
import TestHubEvidenceSection from '../../components/test/TestHubEvidenceSection.astro';
import TestHubProcessPinned from '../../components/test/TestHubProcessPinned.astro';
import TestHubScoreLocations from '../../components/test/TestHubScoreLocations.astro';
import TestHubScoreExample from '../../components/test/TestHubScoreExample.astro';
import TestHubSubscoreBrowse from '../../components/test/TestHubSubscoreBrowse.astro';
import TestHubSubscoreExample from '../../components/test/TestHubSubscoreExample.astro';
import TestHubSidebar from '../../components/test/TestHubSidebar.astro';
import RoundupFaq from '../../components/roundup/RoundupFaq.astro';
import { getTestCategories } from '../../lib/test-framework';
import {
  testHubFaq,
  testHubProcessSteps,
  testHubTrustMetrics,
  testHubVersions,
} from '../../data/test-hub-content';
import { testHubScoredVsInformational } from '../../data/methodology-support-content';
import { testHubUrl } from '../../lib/slugs';
import '../../styles/test-hub.css';
import '../../styles/ratings-tooltips.css';

const categories = getTestCategories();
const chatCategory = categories.find((c) => c.key === 'chat');
const testFaqItems = testHubFaq.map((item) => ({
  question: item.q,
  answer: item.a,
}));
const pageTitle = 'How We Test AI Girlfriend Apps — AI Girlfriend Expert';
---

<BaseLayout
  title={pageTitle}
  description="How we test AI girlfriend apps using paid accounts, structured scenarios, and measurable evidence across eight rating categories."
>
  <Header />
  <main class="test-hub">
    <div class="section-container px-4 md:px-8">
      <div class="test-hub__hero">
        <TestBreadcrumbs
          items={[
            { label: 'Home', href: '/' },
            { label: 'How We Test' },
          ]}
        />
        <p class="test-hub__eyebrow">Testing methodology</p>
        <h1 class="test-hub__title">How We Test AI Girlfriend Apps</h1>
        <p class="test-hub__intro">
          In a world where everyone hammers out AI-generated affiliate articles and calls themselves an “expert” who gives honest reviews, we do things differently.
        </p>
        <p class="test-hub__intro test-hub__intro--spaced">
          Every AI girlfriend app mentioned on aigirlfriend.expert goes through a rigorous review process that relies heavily on data-driven scores.
        </p>
        <p class="test-hub__intro test-hub__intro--spaced">
          This page explains our entire scoring process, what those scores mean, and how we calculate them.
        </p>
        <ul class="test-hub__metrics">
          {
            testHubTrustMetrics.map((m) => (
              <li class="test-hub__metric">
                <span class="material-symbols-outlined" aria-hidden="true">{m.icon}</span>
                {m.value}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="test-hub__layout">
        <aside class="test-hub__toc test-hub__toc--desktop" aria-label="Table of contents">
          <TestHubSidebar categories={categories} />
        </aside>

        <article class="test-hub__main">
          <section id="how-scores-work" class="test-hub__section">
            <h2 class="test-hub__h2">How our rating system works</h2>
            <p class="test-hub__lead">
              Our rating system has four levels. Specific evidence is used to calculate subscores, which then determine each category rating. Finally, the weighted category ratings are combined to create the overall performance score.
            </p>
            <p class="test-hub__tooltips-note">
              Scores throughout the site include interactive explanations.
            </p>
            <TestHubHierarchyPipeline />
          </section>

          <section id="overall-score" class="test-hub__section">
            <h2 class="test-hub__h2">Overall performance score</h2>
            <div class="test-hub__split test-hub__split--score-example">
              <div>
                <p class="test-hub__lead">
                  The overall performance score is the final rating shown across the site. It gives you a quick overview of how well an app performs across all eight categories.
                </p>
                <p class="test-hub__lead">
                  It is not a simple average. Each category has a different weight based on how important it is to the overall AI companion experience.
                </p>
                <p class="test-hub__lead">
                  The box on the right shows an example of what an overall performance score looks like.
                </p>
              </div>
              <TestHubScoreExample />
            </div>
          </section>

          <section id="category-scores" class="test-hub__section">
            <h2 class="test-hub__h2">Category scores</h2>
            <p class="test-hub__lead">
              Every app receives a score across eight main categories.
            </p>

            <div class="test-category-index-wrap">
              <ul class="test-category-index" aria-label="Rating categories">
                {
                  categories.map((cat, index) => (
                    <li>
                      <span class="test-category-index__num" aria-hidden="true">{index + 1}.</span>
                      <a href={`#category-${cat.key}`} class="test-category-index__link" data-category-jump>{cat.name}</a>
                    </li>
                  ))
                }
              </ul>
            </div>

            <TestHubCategoryCards categories={categories} />

            <div class="test-hub__origin-story">
              <p class="test-hub__lead">You are probably wondering how we came up with them.</p>
              <p class="test-hub__lead">
                <a class="test-hub__author-link" href="/author/herman-carter">Herman</a>, the CEO of AI Girlfriend Expert, was a beta tester for some of the first AI girlfriend apps back in October 2024, including DreamGF AI, Candy AI, Character AI, and Replika.
              </p>
              <p class="test-hub__lead">
                At the time, chat was the main feature available because AI image generation was still very new and not very good. This forced many AI girlfriend apps to build more features around chatting, such as interactive roleplay scenarios, the ability to upload memory snippets, and even AI group chats.
              </p>
              <p class="test-hub__lead">That is how our Chat and Chat Features categories were born.</p>
              <p class="test-hub__lead">
                Privacy became a category because it is important for any website, especially one with adult content.
              </p>
              <p class="test-hub__lead">
                Pricing is also included because you want to know whether you are getting good value for your money.
              </p>
              <p class="test-hub__lead">
                The other four categories were developed through extensive research and a survey of 100 AI girlfriend users across different platforms. We asked them which features mattered most. We found participants by joining more than 25 Discord servers from different AI girlfriend platforms.
              </p>
            </div>
          </section>

          <section id="subscores" class="test-hub__section">
            <h2 class="test-hub__h2">How subscores work</h2>
            <p class="test-hub__lead">
              Each category is divided into three broad subscores. These organize related measurements into results that are easier to understand and compare.
            </p>

            <hr class="test-hub__divider" />

            {
              chatCategory && (
                <TestHubSubscoreExample
                  categoryName={chatCategory.name}
                  categoryKey={chatCategory.key}
                  subscores={chatCategory.subscores}
                />
              )
            }

            <h3 class="test-hub__h3 test-hub__h3--spaced">Browse all subscores</h3>
            <TestHubSubscoreBrowse categories={categories} />
          </section>

          <section id="evidence" class="test-hub__section">
            <h2 class="test-hub__h2">Evidence points</h2>
            <p class="test-hub__lead">
              Evidence points are the individual measurements collected during testing. They are the foundation of every score. Some are simple yes/no checks; others use percentages, counts, timings, or structured quality assessments.
            </p>
            <TestHubEvidenceSection />
          </section>

          <section id="full-framework" class="test-hub__section">
            <h2 class="test-hub__h2">Explore our full testing framework</h2>
            <TestHubFrameworkAccordion categories={categories} />
          </section>

          <section id="in-practice" class="test-hub__section test-hub__section--process">
            <h2 class="test-hub__h2">How we test AI girlfriend apps in practice</h2>
            <TestHubProcessPinned steps={testHubProcessSteps} />
          </section>

          <section id="across-site" class="test-hub__section">
            <h2 class="test-hub__h2">Where you will see our scores</h2>
            <TestHubScoreLocations />
          </section>

          <section id="beyond-the-score" class="test-hub__section">
            <h2 class="test-hub__h2">Beyond the score</h2>
            <p class="test-hub__lead">
              We aim to keep our reviews as objective as possible, so our recommendations are truly based on data. That said, personal experience, expert analysis, and how a platform actually feels to use still matter. We are humans, after all.
            </p>
            <ul class="test-beyond-links">
              <li class="test-beyond-links__item">
                <a class="test-beyond-links__title" href="/review-process/">
                  Review process
                  <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                </a>
                <p class="test-beyond-links__desc">Written reviews, personal experience, screenshots, galleries, and YouTube video reviews.</p>
              </li>
              <li class="test-beyond-links__item">
                <a class="test-beyond-links__title" href="/test/market-data/">
                  Market data methodology
                  <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                </a>
                <p class="test-beyond-links__desc">Google Trends, search interest, growth, internal popularity rankings, and competitive comparisons.</p>
              </li>
              <li class="test-beyond-links__item">
                <a class="test-beyond-links__title" href="/editorial-guidelines/">
                  Editorial guidelines
                  <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                </a>
                <p class="test-beyond-links__desc">Independence, fact-checking, corrections, and affiliate disclosures.</p>
              </li>
            </ul>
            <h3 class="test-hub__h3">Scored vs informational</h3>
            <table class="test-scored-table">
              <thead>
                <tr>
                  <th>Content type</th>
                  <th>Affects score</th>
                </tr>
              </thead>
              <tbody>
                {
                  testHubScoredVsInformational.map((row) => (
                    <tr>
                      <td>
                        {row.item}
                        {row.note && <span class="test-scored-table__note"> — {row.note}</span>}
                      </td>
                      <td>{row.affectsScore ? 'Yes' : 'No'}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </section>

          <section id="consistency" class="test-hub__section">
            <h2 class="test-hub__h2">How we keep scores consistent</h2>
            <p class="test-hub__lead">Every app is tested using the same categories and the same tasks.</p>
            <p class="test-hub__lead">When privacy information is unclear or unavailable, we do not assume the app is safe.</p>
            <p class="test-hub__lead">Image and video costs are shown in those sections, but they only affect the Pricing score. This prevents us from counting the same thing twice.</p>
            <p class="test-hub__lead">Simply having a feature does not guarantee a high score. The feature also needs to work well.</p>
          </section>

          <section id="updates" class="test-hub__section">
            <h2 class="test-hub__h2">Updates and methodology versions</h2>
            <p class="test-hub__lead">Current methodology: <strong>V3.1</strong> (August 2026). We recalculate or retest when products or methodology versions change.</p>
            <table class="test-version-table">
              <thead>
                <tr>
                  <th>Version</th>
                  <th>Date</th>
                  <th>Main change</th>
                </tr>
              </thead>
              <tbody>
                {
                  testHubVersions.map((v) => (
                    <tr>
                      <td>{v.version}</td>
                      <td>{v.date}</td>
                      <td>{v.change}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </section>

          <RoundupFaq sectionId="faq" sectionClass="test-hub__section" items={testFaqItems} />
        </article>
      </div>
    </div>

    <button type="button" class="test-hub__mobile-toc-btn lg:hidden" data-test-hub-toc-open aria-label="Open table of contents">
      <span class="material-symbols-outlined" aria-hidden="true">description</span>
    </button>

    <div class="test-hub-sheet" data-test-hub-sheet hidden aria-hidden="true">
      <div class="test-hub-sheet__backdrop" data-test-hub-sheet-close tabindex="-1"></div>
      <div class="test-hub-sheet__panel" role="dialog" aria-modal="true" aria-labelledby="test-hub-sheet-title">
        <h2 id="test-hub-sheet-title" class="test-hub-sheet__title">Contents</h2>
        <TestHubSidebar categories={categories} mobile />
      </div>
    </div>
  </main>
  <Footer />

  <script>
    function initTestHubNav() {
      const navs = Array.from(document.querySelectorAll('[data-test-hub-nav]'));
      if (!navs.length || document.documentElement.dataset.testHubNavBound === 'true') return;
      document.documentElement.dataset.testHubNavBound = 'true';

      const sectionLinks = Array.from(
        navs[0].querySelectorAll<HTMLAnchorElement>('[data-test-hub-nav-link]'),
      );
      if (!sectionLinks.length) return;

      const sections = sectionLinks
        .map((link) => {
          const id = link.dataset.sectionId;
          return id ? document.getElementById(id) : null;
        })
        .filter((section): section is HTMLElement => section instanceof HTMLElement);

      const setActive = (id: string | null) => {
        navs.forEach((nav) => {
          nav.querySelectorAll<HTMLAnchorElement>('[data-test-hub-nav-link]').forEach((link) => {
            const active = link.dataset.sectionId === id;
            link.classList.toggle('is-active', active);
            if (active) link.setAttribute('aria-current', 'location');
            else link.removeAttribute('aria-current');
          });
        });
      };

      const scrollOffset = 24;

      navs.forEach((nav) => {
        nav.querySelectorAll<HTMLAnchorElement>('[data-test-hub-nav-link]').forEach((link) => {
          link.addEventListener('click', (event) => {
            const id = link.dataset.sectionId;
            if (!id) return;
            const section = document.getElementById(id);
            if (!section) return;
            event.preventDefault();
            const y = section.getBoundingClientRect().top + window.scrollY - scrollOffset;
            window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
            history.pushState(null, '', `#${id}`);
            setActive(id);
          });
        });
      });

      const updateActiveSection = () => {
        const marker = window.scrollY + scrollOffset + 8;
        let currentId: string | null = sections[0]?.id ?? null;

        for (const section of sections) {
          if (section.offsetTop <= marker) currentId = section.id;
          else break;
        }

        setActive(currentId);
      };

      updateActiveSection();
      window.addEventListener('scroll', updateActiveSection, { passive: true });
      window.addEventListener('resize', updateActiveSection);
    }

    function initTestHubSheet() {
      const sheet = document.querySelector('[data-test-hub-sheet]');
      const openBtn = document.querySelector('[data-test-hub-toc-open]');
      if (!sheet || !openBtn || openBtn.dataset.bound === 'true') return;
      openBtn.dataset.bound = 'true';

      function close() {
        sheet.hidden = true;
        sheet.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('roundup-sheet-open');
      }

      function open() {
        sheet.hidden = false;
        sheet.setAttribute('aria-hidden', 'false');
        document.body.classList.add('roundup-sheet-open');
      }

      openBtn.addEventListener('click', open);
      sheet.querySelector('[data-test-hub-sheet-close]')?.addEventListener('click', close);
      sheet.querySelectorAll('[data-test-hub-sheet-link]').forEach((link) => {
        link.addEventListener('click', close);
      });
    }

    function initCategoryJumpHighlight() {
      const HIGHLIGHT_CLASS = 'is-highlighted';
      const HIGHLIGHT_MS = 2600;
      let highlightTimer: ReturnType<typeof setTimeout> | null = null;

      function getScrollOffset() {
        return 20;
      }

      function flashCard(card: HTMLElement) {
        document.querySelectorAll('.test-category-card.is-highlighted').forEach((el) => {
          el.classList.remove(HIGHLIGHT_CLASS);
        });
        card.classList.remove(HIGHLIGHT_CLASS);
        void card.offsetWidth;
        card.classList.add(HIGHLIGHT_CLASS);
        if (highlightTimer) clearTimeout(highlightTimer);
        highlightTimer = setTimeout(() => card.classList.remove(HIGHLIGHT_CLASS), HIGHLIGHT_MS);
      }

      function scrollToCard(card: HTMLElement) {
        const y = card.getBoundingClientRect().top + window.scrollY - getScrollOffset();
        window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
      }

      function jumpToCategory(hash: string) {
        if (!hash.startsWith('#category-')) return;
        const card = document.querySelector<HTMLElement>(hash);
        if (!card) return;
        scrollToCard(card);
        window.setTimeout(() => flashCard(card), 180);
      }

      document.querySelectorAll('[data-category-jump]').forEach((link) => {
        if (link instanceof HTMLAnchorElement && link.dataset.bound !== 'true') {
          link.dataset.bound = 'true';
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const hash = link.getAttribute('href');
            if (!hash) return;
            history.pushState(null, '', hash);
            jumpToCategory(hash);
          });
        }
      });

      if (document.documentElement.dataset.categoryJumpBound !== 'true') {
        document.documentElement.dataset.categoryJumpBound = 'true';
        window.addEventListener('hashchange', () => {
          jumpToCategory(window.location.hash);
        });
      }

      if (window.location.hash.startsWith('#category-')) {
        requestAnimationFrame(() => jumpToCategory(window.location.hash));
      }
    }

    initTestHubNav();
    initTestHubSheet();
    initCategoryJumpHighlight();
    document.addEventListener('astro:page-load', () => {
      initTestHubNav();
      initTestHubSheet();
      initCategoryJumpHighlight();
    });
  </script>
</BaseLayout>
