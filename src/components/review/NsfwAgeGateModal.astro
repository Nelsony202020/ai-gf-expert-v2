---
import AgeRatingIcon from '../ui/AgeRatingIcon.astro';
---

<div class="nsfw-gate hidden" data-nsfw-gate aria-hidden="true">
  <div class="nsfw-gate__backdrop" data-nsfw-gate-backdrop tabindex="-1"></div>
  <div
    class="nsfw-gate__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="nsfw-gate-title"
    aria-describedby="nsfw-gate-desc"
  >
    <div class="nsfw-gate__icon" aria-hidden="true">
      <AgeRatingIcon size={32} />
    </div>
    <h3 id="nsfw-gate-title" class="nsfw-gate__title">Show 18+ content?</h3>
    <p id="nsfw-gate-desc" class="nsfw-gate__desc">
      This gallery contains adult images and videos. Please confirm that you are 18 or older to continue.
    </p>

    <label class="nsfw-gate__check">
      <input type="checkbox" data-nsfw-gate-age />
      <span class="nsfw-gate__check-box" aria-hidden="true"></span>
      <span class="nsfw-gate__check-text">
        <span class="nsfw-gate__check-label">I am 18 or older</span>
        <span class="nsfw-gate__check-hint">You must confirm to view 18+ content.</span>
      </span>
    </label>

    <label class="nsfw-gate__check">
      <input type="checkbox" data-nsfw-gate-remember />
      <span class="nsfw-gate__check-box" aria-hidden="true"></span>
      <span class="nsfw-gate__check-text">
        <span class="nsfw-gate__check-label">Remember my choice on this device</span>
        <span class="nsfw-gate__check-hint">You can switch back to Safe only anytime.</span>
      </span>
    </label>

    <div class="nsfw-gate__actions">
      <button type="button" class="nsfw-gate__btn nsfw-gate__btn--cancel" data-nsfw-gate-cancel>Cancel</button>
      <button type="button" class="nsfw-gate__btn nsfw-gate__btn--confirm" data-nsfw-gate-confirm disabled>
        <AgeRatingIcon size={20} />
        Show 18+ content
      </button>
    </div>

    <p class="nsfw-gate__footer">
      <span class="material-symbols-outlined text-[14px]">lock</span>
      Your privacy and safety come first
    </p>
  </div>
</div>

<style is:global>
  .nsfw-gate {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .nsfw-gate.hidden {
    display: none;
  }

  .nsfw-gate__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 55%);
    backdrop-filter: blur(3px);
  }

  .nsfw-gate__dialog {
    position: relative;
    width: min(420px, 100%);
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
    padding: 28px 24px 22px;
    border-radius: 16px;
    border: 1px solid var(--color-surface-variant);
    background: #fff;
    box-shadow: 0 20px 50px rgb(0 0 0 / 22%);
    text-align: center;
  }

  .nsfw-gate__icon {
    display: flex;
    justify-content: center;
    margin-bottom: 14px;
  }

  .nsfw-gate__icon .material-symbols-outlined {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    font-size: 2rem;
    border-radius: 50%;
    background: rgb(219 39 119 / 12%);
    color: var(--color-accent);
  }

  .nsfw-gate__title {
    margin: 0 0 8px;
    font-size: 1.35rem;
    font-weight: 900;
    color: var(--color-on-surface);
  }

  .nsfw-gate__desc {
    margin: 0 0 20px;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-on-surface-variant);
  }

  .nsfw-gate__check {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    text-align: left;
    padding: 12px 14px;
    margin-bottom: 10px;
    border: 1px solid var(--color-surface-variant);
    border-radius: 12px;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .nsfw-gate__check:hover {
    border-color: rgb(219 39 119 / 35%);
    background: rgb(219 39 119 / 3%);
  }

  .nsfw-gate__check input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .nsfw-gate__check-box {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin-top: 2px;
    border: 2px solid var(--color-surface-variant);
    border-radius: 5px;
    background: #fff;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .nsfw-gate__check input:checked + .nsfw-gate__check-box {
    border-color: var(--color-accent);
    background: var(--color-accent);
    box-shadow: inset 0 0 0 2px #fff;
  }

  .nsfw-gate__check-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .nsfw-gate__check-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-on-surface);
  }

  .nsfw-gate__check-hint {
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--color-on-surface-variant);
  }

  .nsfw-gate__actions {
    display: flex;
    gap: 10px;
    margin-top: 18px;
  }

  .nsfw-gate__btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 44px;
    padding: 10px 14px;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 800;
    cursor: pointer;
    transition: opacity 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .nsfw-gate__btn--cancel {
    border: 1px solid var(--color-surface-variant);
    background: #fff;
    color: var(--color-on-surface);
  }

  .nsfw-gate__btn--cancel:hover {
    border-color: var(--color-on-surface-variant);
    background: var(--color-surface-container-low);
  }

  .nsfw-gate__btn--confirm {
    border: none;
    background: var(--color-accent);
    color: #fff;
  }

  .nsfw-gate__btn--confirm:hover:not(:disabled) {
    background: #be185d;
  }

  .nsfw-gate__btn--confirm:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .nsfw-gate__footer {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 16px 0 0;
    font-size: 0.75rem;
    color: var(--color-tertiary);
  }

  [data-theme='dark'] .nsfw-gate__dialog {
    background: #1a1f18;
    border-color: #2a3328;
  }

  [data-theme='dark'] .nsfw-gate__check {
    border-color: #2a3328;
    background: rgb(255 255 255 / 2%);
  }

  [data-theme='dark'] .nsfw-gate__check-box {
    background: #121612;
    border-color: #2a3328;
  }

  [data-theme='dark'] .nsfw-gate__btn--cancel {
    background: #121612;
    border-color: #2a3328;
    color: #ececec;
  }
</style>
