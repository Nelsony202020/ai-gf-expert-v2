---
import type { StoryHighlightCharacter } from '../../../data/products';
import VerifiedCheck from '../ui/VerifiedCheck.astro';

export type { StoryHighlightCharacter };

interface Props {
  characters: StoryHighlightCharacter[];
  productName: string;
  heading?: string;
  badge?: string;
  hideHeading?: boolean;
  maxDisplay?: number;
  showPlatform?: boolean;
  showVerified?: boolean;
  layout?: 'contained' | 'full-bleed';
  staticCarousel?: boolean;
  featuredGrid?: boolean;
  manualDrag?: boolean;
}

const {
  characters,
  productName,
  heading,
  badge,
  hideHeading = false,
  maxDisplay = 4,
  showPlatform = false,
  showVerified = true,
  layout = 'contained',
  staticCarousel = false,
  featuredGrid = false,
  manualDrag = false,
} = Astro.props;

const displayChars = characters.slice(0, maxDisplay);
const carouselChars = manualDrag || !staticCarousel ? [...displayChars, ...displayChars] : displayChars;
const dataId = `char-stories-${productName.replace(/\s+/g, '-').toLowerCase()}`;
const headingText = heading ?? `Meet some of ${productName}'s characters`;

function segmentPath(index: number, total: number, radius = 46): string {
  const gapDegrees = total > 1 ? 12 : 0;
  const segmentDegrees = (360 - gapDegrees * total) / total;
  const startAngle = -90 + index * (segmentDegrees + gapDegrees);
  const endAngle = startAngle + segmentDegrees;
  const startRad = (startAngle * Math.PI) / 180;
  const endRad = (endAngle * Math.PI) / 180;
  const x1 = 50 + radius * Math.cos(startRad);
  const y1 = 50 + radius * Math.sin(startRad);
  const x2 = 50 + radius * Math.cos(endRad);
  const y2 = 50 + radius * Math.sin(endRad);
  const largeArc = segmentDegrees > 180 ? 1 : 0;
  return `M ${x1} ${y1} A ${radius} ${radius} 0 ${largeArc} 1 ${x2} ${y2}`;
}
---

<section
  class:list={[
    'char-stories',
    layout === 'full-bleed' && 'char-stories--full-bleed',
    showPlatform && 'char-stories--with-platform',
    staticCarousel && 'char-stories--static',
    featuredGrid && 'char-stories--featured-grid',
    manualDrag && 'char-stories--manual-drag',
  ]}
  data-char-stories={dataId}
  data-char-static={staticCarousel ? 'true' : undefined}
  data-char-manual-drag={manualDrag ? 'true' : undefined}
>
  {
    !hideHeading && (
      <h3 class="char-stories__heading">
        <img src="/brand/herman-in-love-icon.svg" alt="" class="char-stories__heading-icon" width="44" height="44" />
        {headingText}
        {badge && <span class="char-stories__badge">{badge}</span>}
      </h3>
    )
  }

  <div class="char-stories__carousel-outer">
    <div class="char-stories__carousel" data-char-carousel tabindex="0">
      <div class="char-stories__track" data-char-track>
        {
          carouselChars.map((char, i) => {
            const origIndex = i % displayChars.length;
            const slideCount = char.storySlides.length;
            const thumb = char.storySlides[char.storySlides.length - 1] ?? char.avatar;
            return (
              <button
                type="button"
                class="char-stories__item"
                data-story-open={origIndex}
                aria-label={`View ${char.name}'s story`}
              >
                <div class="char-stories__ring-wrap">
                  <svg class="char-stories__ring" viewBox="0 0 100 100" aria-hidden="true">
                    {
                      Array.from({ length: slideCount }).map((_, seg) => (
                        <path
                          d={segmentPath(seg, slideCount)}
                          fill="none"
                          stroke-width="5"
                          stroke-linecap="round"
                          class="char-stories__segment"
                          data-segment={seg}
                        />
                      ))
                    }
                  </svg>
                  <div class="char-stories__avatar-wrap">
                    <img src={thumb} alt={char.name} class="char-stories__avatar" loading="lazy" width="64" height="64" />
                  </div>
                </div>
                <span class="char-stories__label-stack">
                  <span class="char-stories__name-row">
                    <span class="char-stories__name">{char.name}</span>
                    {showVerified && <VerifiedCheck class="char-stories__verified" />}
                  </span>
                  {showPlatform && char.platform && <span class="char-stories__platform">{char.platform}</span>}
                </span>
              </button>
            );
          })
        }
      </div>
    </div>
  </div>

  <script type="application/json" id={`${dataId}-data`} set:html={JSON.stringify(displayChars)} />

  <div class="char-stories__viewer hidden" data-story-viewer aria-hidden="true">
    <div class="char-stories__backdrop" data-story-close />
    <div class="char-stories__modal" role="dialog" aria-modal="true" aria-label="Character story">
      <div class="char-stories__progress" data-story-progress />
      <button type="button" class="char-stories__close" data-story-close aria-label="Close">
        <span class="material-symbols-outlined">close</span>
      </button>
      <div class="char-stories__modal-header">
        <img src="" alt="" width="32" height="32" data-story-header-avatar />
        <div>
          <a href="#" class="char-stories__header-name" data-story-header-link />
          <p data-story-header-type />
        </div>
      </div>
      <div class="char-stories__slide-stage">
        <img src="" alt="" class="char-stories__slide" data-story-slide />
      </div>
      <div class="char-stories__top-fade" aria-hidden="true" />
      <div class="char-stories__bottom-fade" aria-hidden="true" />
      <button type="button" class="char-stories__tap char-stories__tap--prev" data-story-prev aria-label="Previous" />
      <button type="button" class="char-stories__tap char-stories__tap--next" data-story-next aria-label="Next" />
      <button type="button" class="char-stories__nav-arrow char-stories__nav-arrow--prev" data-story-nav-prev aria-label="Previous slide">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button type="button" class="char-stories__nav-arrow char-stories__nav-arrow--next" data-story-nav-next aria-label="Next slide">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
      <div class="char-stories__footer">
        <input
          type="text"
          class="char-stories__input"
          placeholder="Send message..."
          data-story-input
          autocomplete="off"
        />
        <button type="button" class="char-stories__like" data-story-like aria-label="Like">
          <span class="material-symbols-outlined char-stories__like-icon">favorite</span>
        </button>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ dataId }}>
  function initCharStories() {
    const root = document.querySelector(`[data-char-stories="${dataId}"]`);
    if (!root || root.dataset.init) return;
    root.dataset.init = 'true';

    const isStatic = root.dataset.charStatic === 'true';
    const isManualDrag = root.dataset.charManualDrag === 'true';
    const allowAutoScroll = !isStatic;
    const allowDrag = allowAutoScroll || isManualDrag;

    const dataEl = document.getElementById(`${dataId}-data`);
    if (!dataEl) return;
    let characters = [];
    try { characters = JSON.parse(dataEl.textContent || '[]'); } catch { return; }

    const carousel = root.querySelector('[data-char-carousel]');
    const track = root.querySelector('[data-char-track]');
    const viewer = root.querySelector('[data-story-viewer]');
    const progress = root.querySelector('[data-story-progress]');
    const slideEl = root.querySelector('[data-story-slide]');
    const nameLinkEl = root.querySelector('[data-story-header-link]');
    const typeEl = root.querySelector('[data-story-header-type]');
    const avatarEl = root.querySelector('[data-story-header-avatar]');
    const likeBtn = root.querySelector('[data-story-like]');
    const chatInput = root.querySelector('[data-story-input]');
    const modal = root.querySelector('.char-stories__modal');
    if (!carousel || !track || !viewer || !slideEl || !modal) return;

    let offset = 0;
    let velocity = 0;
    let paused = false;
    let dragging = false;
    let dragX = 0;
    let dragStart = 0;
    let lastDragX = 0;
    let lastDragTime = 0;
    let raf = null;
    let charIndex = 0;
    let slideIndex = 0;
    let timer = null;
    let didDrag = false;

    const STORY_DURATION = 5200;
    const AUTO_SPEED = 0.05;
    const FRICTION = 0.982;
    const MIN_VELOCITY = 0.04;
    const half = () => track.scrollWidth / 2;

    function wrapOffset() {
      const h = half();
      if (h <= 0) return;
      offset = ((offset % h) + h) % h;
    }

    function applyTransform() {
      if (allowDrag) wrapOffset();
      track.style.transform = allowDrag ? `translateX(-${offset}px)` : '';
    }

    function tick() {
      if (isStatic && !isManualDrag) return;
      if (!dragging) {
        if (allowAutoScroll && !paused && Math.abs(velocity) < MIN_VELOCITY) {
          offset += AUTO_SPEED;
        } else if (Math.abs(velocity) >= MIN_VELOCITY) {
          offset += velocity;
          velocity *= FRICTION;
          if (Math.abs(velocity) < MIN_VELOCITY) velocity = 0;
        }
        applyTransform();
      }
      raf = requestAnimationFrame(tick);
    }
    if (allowAutoScroll || isManualDrag) raf = requestAnimationFrame(tick);

    carousel.addEventListener('mouseenter', () => {
      if (!allowAutoScroll) return;
      paused = true;
      carousel.classList.add('is-paused');
    });
    carousel.addEventListener('mouseleave', () => {
      if (!allowAutoScroll) return;
      if (viewer.classList.contains('hidden')) {
        paused = false;
        dragging = false;
        carousel.classList.remove('is-paused', 'is-dragging');
      }
    });

    function endDrag() {
      if (!dragging) return;
      dragging = false;
      carousel.classList.remove('is-dragging');
      paused = false;
    }

    carousel.addEventListener('mousedown', (e) => {
      if (!allowDrag || e.button !== 0) return;
      dragging = true;
      didDrag = false;
      paused = true;
      velocity = 0;
      dragX = e.clientX;
      lastDragX = e.clientX;
      lastDragTime = Date.now();
      dragStart = offset;
      carousel.classList.add('is-dragging');
      e.preventDefault();
    });

    window.addEventListener('mousemove', (e) => {
      if (!allowDrag || !dragging) return;
      const now = Date.now();
      const dx = dragX - e.clientX;
      if (Math.abs(dx) > 4) didDrag = true;
      offset = dragStart + dx;
      applyTransform();
      const dt = Math.max(now - lastDragTime, 1);
      velocity = ((lastDragX - e.clientX) / dt) * 9;
      lastDragX = e.clientX;
      lastDragTime = now;
    });

    window.addEventListener('mouseup', endDrag);

    carousel.addEventListener('touchstart', (e) => {
      if (!allowDrag || e.touches.length !== 1) return;
      dragging = true;
      didDrag = false;
      paused = true;
      velocity = 0;
      dragX = e.touches[0].clientX;
      lastDragX = e.touches[0].clientX;
      lastDragTime = Date.now();
      dragStart = offset;
      carousel.classList.add('is-dragging');
    }, { passive: true });

    carousel.addEventListener('touchmove', (e) => {
      if (!allowDrag || !dragging || e.touches.length !== 1) return;
      const now = Date.now();
      const clientX = e.touches[0].clientX;
      const dx = dragX - clientX;
      if (Math.abs(dx) > 4) didDrag = true;
      offset = dragStart + dx;
      applyTransform();
      const dt = Math.max(now - lastDragTime, 1);
      velocity = ((lastDragX - clientX) / dt) * 9;
      lastDragX = clientX;
      lastDragTime = now;
    }, { passive: true });

    carousel.addEventListener('touchend', endDrag);
    carousel.addEventListener('touchcancel', endDrag);

    function clearTimer() { if (timer) { clearTimeout(timer); timer = null; } }

    function renderBars(count, active) {
      if (!progress) return;
      progress.innerHTML = '';
      for (let i = 0; i < count; i++) {
        const b = document.createElement('span');
        b.className = 'char-stories__bar' + (i < active ? ' is-done' : i === active ? ' is-active' : '');
        progress.appendChild(b);
      }
    }

    function updateHeader(char) {
      if (nameLinkEl) {
        nameLinkEl.textContent = char.name;
        nameLinkEl.href = char.profileUrl || '#';
      }
      if (typeEl) typeEl.textContent = char.archetype;
      if (avatarEl) { avatarEl.src = char.avatar; avatarEl.alt = char.name; }
    }

    function goToNextCharacter() {
      if (modal.classList.contains('is-char-switching') || modal.classList.contains('is-char-entering')) return;

      clearTimer();
      modal.classList.add('is-char-switching');

      setTimeout(() => {
        charIndex = (charIndex + 1) % characters.length;
        slideIndex = 0;
        if (likeBtn) likeBtn.classList.remove('is-liked');

        const char = characters[charIndex];
        if (!char?.storySlides?.length) {
          modal.classList.remove('is-char-switching');
          return;
        }

        slideEl.src = char.storySlides[0];
        updateHeader(char);
        renderBars(char.storySlides.length, 0);

        modal.classList.remove('is-char-switching');
        modal.classList.add('is-char-entering');

        setTimeout(() => {
          modal.classList.remove('is-char-entering');
          startSlideTimer();
        }, 320);
      }, 260);
    }

    function advanceSlide() {
      const char = characters[charIndex];
      if (!char?.storySlides?.length) return;
      slideIndex++;
      if (slideIndex >= char.storySlides.length) {
        goToNextCharacter();
        return;
      }
      showSlide();
    }

    function updateNavArrows() {
      const prevArrow = root.querySelector('[data-story-nav-prev]');
      if (prevArrow) prevArrow.classList.toggle('is-visible', slideIndex > 0);
    }

    function startSlideTimer() {
      clearTimer();
      if (progress) {
        progress.querySelectorAll('.char-stories__bar').forEach((bar, i) => {
          bar.classList.remove('is-active', 'is-done');
          if (i < slideIndex) bar.classList.add('is-done');
          else if (i === slideIndex) {
            bar.classList.add('is-active');
            void bar.offsetWidth;
          }
        });
      }
      timer = setTimeout(advanceSlide, STORY_DURATION);
    }

    function showSlide() {
      const char = characters[charIndex];
      if (!char?.storySlides?.length) return;
      if (slideIndex >= char.storySlides.length) slideIndex = 0;
      if (slideIndex < 0) slideIndex = char.storySlides.length - 1;
      modal.classList.remove('is-char-switching', 'is-char-entering');
      slideEl.src = char.storySlides[slideIndex];
      updateHeader(char);
      renderBars(char.storySlides.length, slideIndex);
      updateNavArrows();
      startSlideTimer();
    }

    function mountViewerToBody() {
      if (viewer.parentElement === document.body) return;
      viewer.dataset.charStoriesPlaceholder = 'true';
      document.body.appendChild(viewer);
    }

    function restoreViewer() {
      if (viewer.parentElement !== document.body || !root) return;
      root.appendChild(viewer);
      delete viewer.dataset.charStoriesPlaceholder;
    }

    function openViewer(i) {
      if (didDrag) { didDrag = false; return; }
      charIndex = i; slideIndex = 0; paused = true;
      if (likeBtn) likeBtn.classList.remove('is-liked');
      if (chatInput) chatInput.value = '';
      mountViewerToBody();
      viewer.classList.remove('hidden');
      viewer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      showSlide();
    }

    function closeViewer() {
      clearTimer();
      viewer.classList.add('hidden');
      viewer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      restoreViewer();
      paused = false;
    }

    root.querySelectorAll('[data-story-open]').forEach((btn) => {
      btn.addEventListener('click', () => openViewer(Number(btn.getAttribute('data-story-open'))));
    });
    root.querySelectorAll('[data-story-close]').forEach((el) => el.addEventListener('click', closeViewer));
    root.querySelector('[data-story-next]')?.addEventListener('click', (e) => {
      e.stopPropagation();
      advanceSlide();
    });
    root.querySelector('[data-story-prev]')?.addEventListener('click', (e) => {
      e.stopPropagation();
      slideIndex--;
      showSlide();
    });
    root.querySelector('[data-story-nav-prev]')?.addEventListener('click', (e) => {
      e.stopPropagation();
      slideIndex--;
      showSlide();
    });
    root.querySelector('[data-story-nav-next]')?.addEventListener('click', (e) => {
      e.stopPropagation();
      advanceSlide();
    });

    likeBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      likeBtn.classList.toggle('is-liked');
      likeBtn.classList.remove('is-animating');
      void likeBtn.offsetWidth;
      likeBtn.classList.add('is-animating');
      setTimeout(() => likeBtn.classList.remove('is-animating'), 600);
    });

    chatInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        chatInput.value = '';
      }
    });

    chatInput?.addEventListener('click', (e) => e.stopPropagation());
    nameLinkEl?.addEventListener('click', (e) => e.stopPropagation());
    document.addEventListener('keydown', (e) => {
      if (viewer.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeViewer();
    });
  }

  initCharStories();
  document.addEventListener('astro:page-load', initCharStories);
</script>

<style is:global>
  .char-stories { width: 100%; max-width: 100%; overflow: hidden; }
  .char-stories--static { overflow: visible; }
  .char-stories--static:not(.char-stories--manual-drag) .char-stories__carousel {
    overflow: visible;
    cursor: default;
    padding-left: 0;
    padding-right: 0;
  }
  .char-stories--static:not(.char-stories--manual-drag) .char-stories__track {
    flex-wrap: wrap;
    justify-content: center;
    width: 100%;
    gap: 18px 14px;
    transform: none !important;
  }
  .char-stories--static:not(.char-stories--manual-drag) .char-stories__carousel.is-paused,
  .char-stories--static:not(.char-stories--manual-drag) .char-stories__carousel.is-dragging {
    cursor: default;
  }
  .char-stories--full-bleed {
    width: 100%;
    max-width: none;
    overflow: visible;
  }
  .char-stories__heading {
    display: flex; align-items: center; flex-wrap: wrap; gap: 8px;
    margin: 0 0 14px; font-size: 1.125rem; font-weight: 800; color: var(--color-on-surface);
  }
  .char-stories__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    font-size: 0.625rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .char-stories__heading-icon { flex-shrink: 0; width: 44px; height: 44px; object-fit: contain; }
  .char-stories__carousel-outer {
    width: 100%;
    max-width: 100%;
  }
  .char-stories--full-bleed .char-stories__carousel-outer {
    width: 100%;
    margin-left: 0;
    overflow: hidden;
  }
  .char-stories--full-bleed .char-stories__carousel {
    width: 100%;
    max-width: none;
    padding-left: 1rem;
    padding-right: 1rem;
  }
  @media (min-width: 768px) {
    .char-stories--full-bleed .char-stories__carousel {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }
  @media (min-width: 1024px) {
    .char-stories--full-bleed .char-stories__carousel {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }
  .char-stories--full-bleed.char-stories--with-platform .char-stories__item {
    width: 104px;
  }
  .char-stories--full-bleed .char-stories__ring-wrap {
    width: 80px;
    height: 80px;
  }
  .char-stories--full-bleed .char-stories__ring {
    width: 80px;
    height: 80px;
  }
  .char-stories--full-bleed .char-stories__track {
    gap: 18px;
  }
  .char-stories--full-bleed .char-stories__name {
    font-size: 12px;
  }
  .char-stories--full-bleed .char-stories__platform {
    max-width: 104px;
    font-size: 10px;
  }
  .char-stories--full-bleed.char-stories--with-platform .char-stories__name-row {
    max-width: 104px;
  }
  @media (min-width: 1024px) {
    .char-stories--full-bleed.char-stories--with-platform .char-stories__item {
      width: 132px;
    }
    .char-stories--full-bleed .char-stories__ring-wrap {
      width: 96px;
      height: 96px;
    }
    .char-stories--full-bleed .char-stories__ring {
      width: 96px;
      height: 96px;
    }
    .char-stories--full-bleed .char-stories__track {
      gap: 28px;
    }
    .char-stories--full-bleed .char-stories__name {
      font-size: 13px;
    }
    .char-stories--full-bleed .char-stories__platform {
      max-width: 132px;
      font-size: 11px;
    }
    .char-stories--full-bleed.char-stories--with-platform .char-stories__name-row {
      max-width: 132px;
    }
  }
  .char-stories__carousel {
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    cursor: grab;
    user-select: none;
    padding-top: 0.25rem;
    padding-bottom: 0.5rem;
  }
  .char-stories__carousel.is-paused { cursor: pointer; }
  .char-stories__carousel.is-dragging { cursor: grabbing; }
  .char-stories__track {
    display: flex; flex-direction: row; flex-wrap: nowrap;
    align-items: flex-start; gap: 14px; width: max-content;
  }
  .char-stories__item {
    flex: 0 0 auto; display: flex; flex-direction: column; align-items: center;
    gap: 6px; width: 72px; padding: 0; border: none; background: none; cursor: inherit;
  }
  .char-stories--with-platform .char-stories__item { width: 92px; }
  .char-stories__label-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    width: 100%;
  }
  .char-stories__platform {
    display: block;
    max-width: 92px;
    font-size: 9px;
    font-weight: 600;
    line-height: 1.25;
    text-align: center;
    color: var(--color-tertiary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .char-stories__ring-wrap { position: relative; width: 64px; height: 64px; flex-shrink: 0; }
  .char-stories__ring { position: absolute; inset: 0; width: 64px; height: 64px; }
  .char-stories__segment { stroke: #db2777; }
  .char-stories__avatar-wrap {
    position: absolute; inset: 5px; border-radius: 999px; background: #fff; padding: 2px;
  }
  .char-stories__avatar { width: 100%; height: 100%; border-radius: 999px; object-fit: cover; display: block; }
  .char-stories__name-row {
    display: inline-flex; align-items: center; justify-content: center; gap: 5px;
    max-width: 100%;
  }
  .char-stories--with-platform .char-stories__name-row { max-width: 92px; }
  .char-stories__name {
    font-size: 10px; font-weight: 800; text-align: center; color: var(--color-on-surface);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;
