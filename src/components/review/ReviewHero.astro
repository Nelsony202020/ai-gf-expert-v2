---
import type { Product } from '../../data/products';
import { getAuthor } from '../../data/authors';
import Gallery from './Gallery.astro';
import RatingSidebar from './RatingSidebar.astro';
import MethodologyTooltip from './tooltips/MethodologyTooltip.astro';
import InfoIcon from '../ui/InfoIcon.astro';
import AuthorBioPopover from './AuthorBioPopover.astro';
import VerifiedCheck from '../ui/VerifiedCheck.astro';
import ShareMenu from '../ui/ShareMenu.astro';
import Breadcrumbs from '../ui/Breadcrumbs.astro';

interface Props {
  product: Product;
  shareUrl?: string;
}

const { product, shareUrl } = Astro.props;
const shareTitle = `${product.name} Review — AI Girlfriend Expert`;
---

<section class="section-container pt-8 md:pt-12 pb-10 px-4 md:px-8">
  <!-- Title block -->
  <div class="flex flex-col gap-4 mb-8">
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Reviews', href: '/apps' },
        { label: product.name },
      ]}
    />

    <h1 class="text-4xl md:text-6xl font-black text-on-surface tracking-tight">
      {product.name} <span class="font-serif italic font-normal text-on-surface">Review</span>
    </h1>

    <div class="article-meta-row mb-0">
      <span>Reviewed {product.reviewedDate}</span>
      <span class="article-meta-row__sep" aria-hidden="true">·</span>
      <span>Updated {product.modifiedDate}</span>
      <span class="article-meta-row__sep" aria-hidden="true">·</span>
      <span class="article-meta-row__methodology">
        {product.methodology}
        <MethodologyTooltip id={`hero-methodology-${product.slug}`}>
          <InfoIcon size="xs" class="text-tertiary hover:text-accent" />
        </MethodologyTooltip>
      </span>
      <span class="article-meta-row__sep article-meta-row__sep--before-share" aria-hidden="true">·</span>
      <ShareMenu shareTitle={shareTitle} shareUrl={shareUrl} variant="inline" />
    </div>
  </div>

  <!-- Authors -->
  <div class="flex flex-col md:flex-row md:items-center justify-between border-b border-surface-variant pb-6 mb-8">
    <div class="flex flex-wrap items-center gap-x-6 gap-y-4">
      {
        product.authors.map((author, i) => {
          const profile = author.slug ? getAuthor(author.slug) : undefined;
          return (
            <>
              {i > 0 && <div class="w-px h-10 bg-surface-variant hidden md:block" />}
              <div class={`flex items-center gap-3 ${profile ? 'relative' : ''}`}>
                <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-white shadow-sm shrink-0 bg-white">
                  <img alt={author.name} class="w-full h-full object-contain p-0.5" src={author.avatar} />
                </div>
                <div class="flex flex-col">
                  {
                    profile ? (
                      <button
                        type="button"
                        class="flex items-center gap-1.5 text-left group overflow-visible"
                        data-author-trigger={author.slug}
                      >
                        <span class="text-sm font-bold group-hover:underline cursor-pointer">{author.name}</span>
                        {author.verified && (
                          <VerifiedCheck class="w-[18px] h-[18px] shrink-0" />
                        )}
                      </button>
                    ) : (
                      <div class="flex items-center gap-1.5 overflow-visible">
                        <span class="text-sm font-bold">{author.name}</span>
                        {author.verified && (
                          <VerifiedCheck class="w-[18px] h-[18px] shrink-0" />
                        )}
                      </div>
                    )
                  }
                  <span class="text-[11px] text-tertiary font-medium">{author.role}</span>
                </div>
                {profile && <AuthorBioPopover author={profile} />}
              </div>
            </>
          );
        })
      }
    </div>
  </div>

  <!-- Gallery + sticky ratings -->
  <div class="flex flex-col lg:flex-row gap-8">
    <div class="lg:w-[68%]">
      <Gallery images={product.gallery} product={product} />
    </div>
    <div class="lg:w-[32%]">
      <RatingSidebar product={product} />
    </div>
  </div>
</section>
