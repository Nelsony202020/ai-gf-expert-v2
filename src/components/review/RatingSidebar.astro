---
import type { Product } from '../../data/products';
import { getScoreVisual, fmtScore } from '../../lib/scores';
import ScorePill from './ScorePill.astro';
import OverallScoreTooltip from './tooltips/OverallScoreTooltip.astro';
import CategoryScoreTooltip from './tooltips/CategoryScoreTooltip.astro';
import InfoIcon from '../ui/InfoIcon.astro';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const overall = getScoreVisual(product.overallScore);
---

<div class="border border-surface-variant rounded-xl overflow-hidden shadow-sm sticky top-24">
  <div class={`${overall.bg} p-5 flex items-center gap-4 min-h-[72px]`}>
    <span class="inline-flex items-center justify-center min-w-[3.25rem] text-3xl font-black tabular-nums">{fmtScore(product.overallScore)}</span>
    <span class="text-lg font-bold flex items-center gap-1.5">
      Overall Performance
      <OverallScoreTooltip product={product}>
        <span class="inline-flex text-white/90 hover:text-white">
          <InfoIcon size="xs" />
        </span>
      </OverallScoreTooltip>
    </span>
  </div>
  <div class="bg-surface-container-low px-4 py-2 text-[11px] font-medium border-b border-surface-variant text-on-surface-variant">
    {product.overallSummary}
  </div>

  <div class="p-4 space-y-3.5">
    {
      product.categories.map((category) => (
        <div class="w-full group">
          <button
            type="button"
            class="flex items-center gap-2.5 cursor-pointer text-left w-full"
            data-goto-category={category.key}
          >
            <ScorePill score={category.score} size="sm" class="shrink-0" />
            <span class="font-bold text-on-surface group-hover:text-accent transition-colors truncate">
              {category.name}
            </span>
            <CategoryScoreTooltip category={category}>
              <span class="inline-flex text-tertiary/70 group-hover:text-accent shrink-0">
                <InfoIcon size="xs" />
              </span>
            </CategoryScoreTooltip>
          </button>
        </div>
      ))
    }

    <div class="pt-4 border-t border-surface-variant"></div>

    <div class="pt-2">
      <a
        href={product.affiliateUrl}
        target="_blank"
        rel="nofollow sponsored noopener"
        class="block w-full bg-brand-cta text-center py-4 rounded-xl font-black text-xl hover:opacity-90 transition shadow-lg mb-2"
      >
        Visit {product.name}
      </a>
      <p class="text-center text-[10px] text-tertiary uppercase font-bold">
        <a href="/legal/affiliate-disclosure" class="inline-flex items-center justify-center gap-1 hover:text-accent transition-colors">
          <span class="material-symbols-outlined text-[12px]">verified_user</span>
          Affiliate Link · Secure Site
        </a>
      </p>
    </div>
  </div>
</div>
