---
interface Props {
  title: string;
  icon: string;
  description: string;
}

const { title, icon, description } = Astro.props;
---

<section class="section-container px-4 md:px-8 py-20 md:py-28">
  <div class="max-w-lg mx-auto text-center flex flex-col items-center">
    <div class="w-16 h-16 rounded-2xl bg-surface-container-low border border-surface-variant flex items-center justify-center mb-6">
      <span class="material-symbols-outlined text-3xl text-primary">{icon}</span>
    </div>
    <h2 class="text-2xl md:text-3xl font-extrabold text-on-surface mb-3">{title}</h2>
    <p class="text-on-surface-variant leading-relaxed mb-6">{description}</p>
    <span
      class="inline-flex items-center gap-2 text-[11px] font-black uppercase tracking-widest text-tertiary bg-surface-container-low border border-surface-variant rounded-full px-4 py-2"
    >
      <span class="material-symbols-outlined text-[14px]">construction</span>
      Coming soon
    </span>
  </div>
</section>
