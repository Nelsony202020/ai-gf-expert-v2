---
import type { RatingCategory } from '../../../data/products';
import { getScoreVisual, fmtScore, weightedValue, equalWeights } from '../../../lib/scores';
import ScorePill from '../ScorePill.astro';
import ProofCarousel from '../ProofCarousel.astro';
import EvidenceTable from '../EvidenceTable.astro';
import SubscoreScoreTooltip from '../tooltips/SubscoreScoreTooltip.astro';
import CategoryScoreTooltip from '../tooltips/CategoryScoreTooltip.astro';
import HierarchyTooltip from '../tooltips/HierarchyTooltip.astro';
import InfoIcon from '../../ui/InfoIcon.astro';

interface Props {
  category: RatingCategory;
  productName?: string;
  open?: boolean;
}

const { category, productName, open = false } = Astro.props;
const visual = getScoreVisual(category.score);

const evidenceBySubscore = category.subscores.map((sub) => {
  const weights = equalWeights(sub.contributors.length);
  const items = sub.contributors.map((c, i) => {
    const internal = c.internalScore ?? sub.score;
    const weight = weights[i] ?? 0;
    return {
      label: c.label,
      value: c.value,
      icon: c.icon,
      internal,
      weight,
      contribution: weightedValue(internal, weight),
    };
  });
  const rawSubTotal = items.reduce((sum, item) => sum + item.contribution, 0);
  return { sub, items, rawSubTotal };
});
---

<div class="border border-surface-variant rounded-xl overflow-hidden shadow-sm" data-category={category.key}>
  <!-- Header — entire row toggles accordion -->
  <div
    role="button"
    tabindex="0"
    data-accordion-toggle
    aria-expanded={open ? 'true' : 'false'}
    aria-label={`Toggle ${category.name} details`}
    class="w-full flex items-center gap-2 p-4 md:p-5 bg-surface-container-low cursor-pointer text-left hover:bg-surface-container/80 transition-colors"
  >
    <div class="flex items-center gap-4 md:gap-6 shrink-0">
      <div class="flex flex-col items-start">
        <ScorePill score={category.score} size="lg" />
        <span class="flex items-center gap-0.5 text-[10px] font-bold uppercase tracking-tighter text-tertiary mt-1">
          Category Score
          <HierarchyTooltip
            id={`cat-hier-${category.key}`}
            highlight="category"
            brandName={productName}
            categoryName={category.name}
            label={`Where the ${category.name} category score sits`}
          >
            <span class="inline-flex text-tertiary hover:text-accent">
              <InfoIcon size="xs" />
            </span>
          </HierarchyTooltip>
        </span>
      </div>
      <div class="h-10 w-px bg-surface-variant hidden sm:block"></div>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-1">
        <span class="text-lg md:text-xl font-bold text-on-surface truncate">{category.name}</span>
        <CategoryScoreTooltip category={category} compact>
          <span class="inline-flex text-tertiary hover:text-accent">
            <span class="material-symbols-outlined text-[18px]">info</span>
          </span>
        </CategoryScoreTooltip>
      </div>
      <p class="text-xs text-tertiary font-medium">Weighting: {category.weight}%</p>
    </div>
    <span class="material-symbols-outlined accordion-icon shrink-0 text-tertiary">expand_more</span>
  </div>

  <!-- Detail -->
  <div data-accordion-content class={open ? '' : 'hidden'}>
    <div class="p-4 md:p-5 border-t border-surface-variant bg-white">
      <div class="grid grid-cols-1 lg:grid-cols-[240px_minmax(0,1fr)] gap-4 lg:gap-6" data-subscore-grid>
        <!-- Col 1: Subscores -->
        <div class="space-y-1 md:space-y-2" data-subscore-list>
          <h4 class="flex items-center gap-1 text-[11px] font-black uppercase tracking-widest text-on-surface-variant mb-2">
            Subscores
            <HierarchyTooltip
              id={`subscores-hier-${category.key}`}
              highlight="subscore"
              brandName={productName}
              categoryName={category.name}
              subscoreName={category.subscores.map((s) => s.name).join(', ')}
              label="Where subscores sit in the rating hierarchy"
            >
              <span class="inline-flex text-tertiary/70 hover:text-primary-container">
                <InfoIcon size="xs" />
              </span>
            </HierarchyTooltip>
          </h4>
          {
            category.subscores.map((sub, i) => {
              const sv = getScoreVisual(sub.score);
              return (
                <div
                  class="subscore-card w-full flex items-center rounded-xl transition-all group cursor-pointer"
                  data-subscore-select
                  data-subscore-index={i}
                  data-active-border={sv.border}
                  data-score-border={sv.border}
                  data-score-text={sv.text}
                  role="button"
                  tabindex="0"
                  aria-selected="false"
                >
                  <div class="flex items-center justify-between flex-1 min-w-0 py-2.5 px-1 gap-2">
                    <div class="flex items-center gap-3 min-w-0 flex-1">
                      <div
                        data-subscore-badge
                        class={`subscore-card__badge shrink-0 w-11 min-w-11 h-9 flex items-center justify-center border-2 rounded-lg text-base font-bold transition-colors box-border ${sv.border} text-on-surface`}
                      >
                        {fmtScore(sub.score)}
                      </div>
                      <div class="flex flex-col min-w-0 flex-1">
                        <span class="flex items-center gap-1 min-w-0">
                          <span data-subscore-label class="text-sm font-bold transition-colors truncate text-on-surface">
                            {sub.name}
                          </span>
                          <SubscoreScoreTooltip categoryKey={category.key} categoryName={category.name} sub={sub} compact>
                            <span class="inline-flex shrink-0 text-tertiary/70 hover:text-primary-container">
                              <span class="material-symbols-outlined text-[14px]">info</span>
                            </span>
                          </SubscoreScoreTooltip>
                        </span>
                        <span class="text-[10px] text-tertiary leading-tight line-clamp-2">{sub.description}</span>
                      </div>
                    </div>
                    <span
                      data-subscore-chevron
                      class={`material-symbols-outlined shrink-0 text-[20px] transition-colors text-tertiary/35 group-hover:text-on-surface/70`}
                    >
                      chevron_right
                    </span>
                  </div>
                </div>
              );
            })
          }
        </div>

        <!-- Col 2: Subscore Breakdown (expanded) -->
        <div class="space-y-4 min-w-0" data-subscore-breakdown data-detail-tier="deep">
          <h4 class="text-[11px] font-black uppercase tracking-widest text-on-surface-variant mb-3">
            Subscore Breakdown
          </h4>
          {
            category.subscores.map((sub, i) => {
              const sv = getScoreVisual(sub.score);
              const evidence = evidenceBySubscore[i];
              const tableId = `evidence-${category.key}-${sub.name}`.replace(/[^a-zA-Z0-9_-]/g, '-');
              return (
                <div data-subscore-panel data-subscore-index={i} class="hidden">
                  <div class="border border-surface-variant rounded-xl overflow-hidden shadow-sm">
                    <div class="p-4 flex items-center gap-2 border-b border-surface-variant bg-white">
                      <span class={`material-symbols-outlined shrink-0 ${sv.text}`} style="font-variation-settings: 'FILL' 1;">
                        check_circle
                      </span>
                      <span class="font-bold text-on-surface text-base">{sub.name}</span>
                    </div>
                    <div class="p-4">
                      {
                        evidence && (
                          <EvidenceTable
                            tableId={tableId}
                            subscoreName={sub.name}
                            subscoreScore={sub.score}
                            categoryKey={category.key}
                            categoryName={category.name}
                            items={evidence.items}
                            rawSubTotal={evidence.rawSubTotal}
                          />
                        )
                      }
                    </div>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>

      <!-- Proof gallery — full width row below grid -->
      {
        category.proof.length > 0 && (
          <div data-detail-tier="deep" class="mt-5 pt-5 border-t border-surface-variant/40">
            <ProofCarousel items={category.proof} />
          </div>
        )
      }
    </div>
  </div>
</div>

<style>
  [data-accordion-toggle][aria-expanded='true'] .accordion-icon {
    transform: rotate(180deg);
  }
  .accordion-icon {
    transition: transform 0.2s ease;
  }
</style>

<script>
  function switchToAllIn() {
    const root = document.querySelector<HTMLElement>('[data-ratings-root]');
    if (!root || root.dataset.detailLevel === 'all-in') return;
    root.dataset.detailLevel = 'all-in';
    document.querySelectorAll<HTMLInputElement>('input[name="detail-level"]').forEach((input) => {
      input.checked = input.value === 'all-in';
    });
    document.dispatchEvent(new CustomEvent('detail-level-change', { detail: { level: 'all-in' } }));
  }

  function initSubscoreSelect() {
    document.querySelectorAll<HTMLElement>('[data-category]').forEach((categoryEl) => {
      if (categoryEl.dataset.subscoreBound === 'true') return;
      categoryEl.dataset.subscoreBound = 'true';

      const cards = Array.from(categoryEl.querySelectorAll<HTMLElement>('[data-subscore-select]'));
      const panels = Array.from(categoryEl.querySelectorAll<HTMLElement>('[data-subscore-panel]'));
      if (!cards.length || !panels.length) return;

      function clearSubscoreSelection() {
        cards.forEach((card) => {
          card.setAttribute('aria-selected', 'false');
          card.classList.remove('subscore-card--active');
          const chevron = card.querySelector<HTMLElement>('[data-subscore-chevron]');
          if (chevron) {
            chevron.classList.remove('text-green-600', 'text-orange-500', 'text-red-600');
            chevron.classList.add('text-tertiary/35');
          }
        });
        panels.forEach((panel) => panel.classList.add('hidden'));
      }

      function selectSubscore(index: string, scrollToBreakdown = false) {
        cards.forEach((card) => {
          const isActive = card.dataset.subscoreIndex === index;
          const activeBorder = card.dataset.activeBorder || 'border-green-600';
          const scoreText = card.dataset.scoreText || 'text-green-600';

          card.setAttribute('aria-selected', isActive ? 'true' : 'false');
          card.classList.toggle('subscore-card--active', isActive);

          const chevron = card.querySelector<HTMLElement>('[data-subscore-chevron]');
          if (chevron) {
            chevron.classList.remove('text-green-600', 'text-orange-500', 'text-red-600', 'text-tertiary/35', 'text-on-surface/70');
            chevron.classList.add(isActive ? scoreText : 'text-tertiary/35');
          }
        });

        panels.forEach((panel) => {
          panel.classList.toggle('hidden', panel.dataset.subscoreIndex !== index);
        });

        if (scrollToBreakdown) {
          const breakdown = categoryEl.querySelector<HTMLElement>('[data-subscore-breakdown]');
          breakdown?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }

      categoryEl.clearSubscoreSelection = clearSubscoreSelection;
      categoryEl.selectSubscore = selectSubscore;

      cards.forEach((card) => {
        card.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).closest('.rt-tooltip-trigger')) return;
          const index = card.dataset.subscoreIndex;
          if (index === undefined) return;

          const root = document.querySelector<HTMLElement>('[data-ratings-root]');
          const isMedium = root?.dataset.detailLevel === 'medium';
          if (isMedium) {
            switchToAllIn();
            selectSubscore(index, true);
            return;
          }

          const isActive = card.getAttribute('aria-selected') === 'true';
          if (isActive) return;
          selectSubscore(index);
        });

        card.addEventListener('keydown', (e) => {
          if (e.key !== 'Enter' && e.key !== ' ') return;
          if ((e.target as HTMLElement).closest('.rt-tooltip-trigger')) return;
          e.preventDefault();
          const index = card.dataset.subscoreIndex;
          if (index === undefined) return;
          selectSubscore(index);
        });
      });

      const root = document.querySelector<HTMLElement>('[data-ratings-root]');
      const content = categoryEl.querySelector<HTMLElement>('[data-accordion-content]');
      const isOpen = content && !content.classList.contains('hidden');
      if (root?.dataset.detailLevel === 'all-in' && isOpen) {
        selectSubscore('0');
      } else {
        clearSubscoreSelection();
      }
    });
  }

  function clearAllSubscores() {
    document.querySelectorAll<HTMLElement>('[data-category]').forEach((el) => {
      el.clearSubscoreSelection?.();
    });
  }

  document.addEventListener('detail-level-change', ((e: CustomEvent) => {
    if (e.detail?.level === 'medium') clearAllSubscores();
    if (e.detail?.level === 'all-in') {
      document.querySelectorAll<HTMLElement>('[data-category]').forEach((el) => {
        const content = el.querySelector<HTMLElement>('[data-accordion-content]');
        if (content && !content.classList.contains('hidden')) {
          el.selectSubscore?.('0');
        }
      });
    }
  }) as EventListener);

  initSubscoreSelect();
  document.addEventListener('astro:page-load', initSubscoreSelect);
</script>
