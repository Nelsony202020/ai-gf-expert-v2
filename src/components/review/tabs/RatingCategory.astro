---
import type { RatingCategory } from '../../../data/products';
import { getScoreVisual, fmtScore, weightedValue, equalWeights } from '../../../lib/scores';
import ScorePill from '../ScorePill.astro';
import InfoIcon from '../../ui/InfoIcon.astro';
import ProofCarousel from '../ProofCarousel.astro';
import { testContributorUrl } from '../../../lib/slugs';

interface Props {
  category: RatingCategory;
  open?: boolean;
}

const { category, open = false } = Astro.props;
const visual = getScoreVisual(category.score);

const subscoreContributions = category.subscores.map((sub) => ({
  ...sub,
  contribution: weightedValue(sub.score, sub.weight),
}));

const evidenceBySubscore = category.subscores.map((sub) => {
  const weights = equalWeights(sub.contributors.length);
  const items = sub.contributors.map((c, i) => {
    const internal = c.internalScore ?? sub.score;
    const weight = weights[i] ?? 0;
    return {
      ...c,
      internal,
      weight,
      contribution: weightedValue(internal, weight),
    };
  });
  const rawSubTotal = items.reduce((sum, item) => sum + item.contribution, 0);
  return { sub, items, rawSubTotal };
});

const categoryRawTotal = subscoreContributions.reduce((sum, c) => sum + c.contribution, 0);
const subscoreSumParts = subscoreContributions.map((c) => c.contribution.toFixed(2)).join(' + ');
---

<div class="border border-surface-variant rounded-xl overflow-hidden shadow-sm" data-category={category.key}>
  <!-- Header -->
  <button
    type="button"
    data-accordion-toggle
    aria-expanded={open ? 'true' : 'false'}
    class="w-full flex items-center justify-between p-4 md:p-5 bg-surface-container-low cursor-pointer text-left"
  >
    <div class="flex items-center gap-4 md:gap-6">
      <div class="flex flex-col items-start">
        <ScorePill score={category.score} size="lg" />
        <span class="text-[10px] font-bold uppercase tracking-tighter text-tertiary mt-1">Category Score</span>
      </div>
      <div class="h-10 w-px bg-surface-variant"></div>
      <div>
        <h3 class="text-lg md:text-xl font-bold text-on-surface flex items-center gap-1">
          {category.name}
          <InfoIcon size="md" />
        </h3>
        <p class="text-xs text-tertiary font-medium">Weighting: {category.weight}%</p>
      </div>
    </div>
    <span class="material-symbols-outlined accordion-icon shrink-0">expand_more</span>
  </button>

  <!-- Detail -->
  <div data-accordion-content class={open ? '' : 'hidden'}>
    <div class="p-4 md:p-5 border-t border-surface-variant bg-white">
      <div class="grid grid-cols-1 lg:grid-cols-[240px_minmax(0,1fr)] gap-4 lg:gap-6" data-subscore-grid>
        <!-- Col 1: Subscores -->
        <div class="space-y-3" data-subscore-list>
          <h4 class="text-[11px] font-black uppercase tracking-widest text-on-surface-variant mb-3 flex items-center gap-1">
            Subscores <InfoIcon size="xs" />
          </h4>
          {
            category.subscores.map((sub, i) => {
              const sv = getScoreVisual(sub.score);
              const isActive = i === 0;
              return (
                <button
                  type="button"
                  data-subscore-select
                  data-subscore-index={i}
                  data-active-border={sv.border}
                  aria-selected={isActive ? 'true' : 'false'}
                  class={`subscore-card w-full flex items-center justify-between p-3 rounded-xl border bg-white shadow-sm transition-all group text-left ${isActive ? sv.border : 'border-surface-variant'}`}
                >
                  <div class="flex items-center gap-3 min-w-0 flex-1 pr-2">
                    <div
                      data-subscore-badge
                      class={`shrink-0 w-12 min-w-12 h-10 flex items-center justify-center border-2 rounded-lg text-lg font-black transition-colors box-border ${isActive ? `${sv.border} text-on-surface` : 'border-surface-variant text-on-surface/40'}`}
                    >
                      {fmtScore(sub.score)}
                    </div>
                    <div class="flex flex-col min-w-0 flex-1">
                      <span data-subscore-label class={`text-sm font-bold transition-colors flex items-center gap-1 ${isActive ? 'text-on-surface' : 'text-on-surface/50 group-hover:text-on-surface'}`}>
                        {sub.name}
                        <InfoIcon size="xs" title={sub.description} />
                      </span>
                      <span class="text-[10px] text-tertiary leading-tight">{sub.description}</span>
                    </div>
                  </div>
                  <span
                    data-subscore-chevron
                    class={`material-symbols-outlined shrink-0 transition-colors ${isActive ? sv.text : 'text-tertiary/40 group-hover:text-on-surface'}`}
                  >
                    chevron_right
                  </span>
                </button>
              );
            })
          }
        </div>

        <!-- Col 2: Subscore Breakdown (expanded) -->
        <div class="space-y-4 min-w-0" data-subscore-breakdown data-detail-tier="deep">
          <h4 class="text-[11px] font-black uppercase tracking-widest text-on-surface-variant mb-3">
            Subscore Breakdown
          </h4>
          {
            category.subscores.map((sub, i) => {
              const sv = getScoreVisual(sub.score);
              const isActive = i === 0;
              return (
                <div data-subscore-panel data-subscore-index={i} class={isActive ? '' : 'hidden'}>
                  <div class="border border-surface-variant rounded-xl overflow-hidden shadow-sm">
                    <div class="p-4 flex items-center justify-between border-b border-surface-variant bg-white">
                      <div class="flex items-center gap-2 min-w-0">
                        <span class={`material-symbols-outlined shrink-0 ${sv.text}`} style="font-variation-settings: 'FILL' 1;">
                          check_circle
                        </span>
                        <span class="font-bold text-on-surface text-lg truncate">{sub.name}</span>
                      </div>
                      <span class={`text-xl font-black shrink-0 ${sv.text}`}>{fmtScore(sub.score)}</span>
                    </div>
                    <div class="p-4 space-y-4">
                      <div>
                        <p class="text-[11px] font-bold text-tertiary mb-2 uppercase tracking-tighter">
                          Evidence
                          <span class="font-normal normal-case text-tertiary/60">(measured results)</span>
                        </p>
                        <div class="flex flex-wrap gap-2 mb-4">
                          {
                            sub.contributors.map((c) => (
                              <a
                                href={testContributorUrl(category.key, sub.name, c.label)}
                                class="px-3 py-1.5 rounded-full border border-surface-variant text-[11px] font-bold flex items-center gap-1.5 bg-white hover:border-primary-container hover:text-primary-container transition-colors"
                              >
                                {c.icon && <span class="material-symbols-outlined text-[16px]">{c.icon}</span>}
                                {c.label}
                              </a>
                            ))
                          }
                        </div>
                        <div class="rounded-xl border border-surface-variant overflow-hidden">
                          {
                            sub.contributors.map((c, ci) => (
                              <a
                                href={testContributorUrl(category.key, sub.name, c.label)}
                                class={`flex justify-between items-center gap-4 text-[13px] px-4 py-3 hover:bg-surface-container-low transition-colors group ${ci < sub.contributors.length - 1 ? 'border-b border-surface-variant/60' : ''}`}
                              >
                                <span class="text-on-surface-variant group-hover:text-primary-container flex items-center gap-1.5 underline-offset-2 group-hover:underline">
                                  {c.icon && <span class="material-symbols-outlined text-[16px] opacity-60">{c.icon}</span>}
                                  {c.label}
                                </span>
                                <span class="font-bold text-on-surface tabular-nums shrink-0">{c.value}</span>
                              </a>
                            ))
                          }
                        </div>
                      </div>
                      <p class="text-[11px] text-tertiary flex items-start gap-1.5">
                        <InfoIcon size="xs" class="mt-0.5 shrink-0" />
                        Each evidence point is scored internally (0–10), then combined into the {sub.name} subscore.
                      </p>
                    </div>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>

      <!-- Proof gallery — full width row below grid -->
      {
        category.proof.length > 0 && (
          <div data-detail-tier="deep" class="mt-5 pt-5 border-t border-surface-variant/40">
            <ProofCarousel items={category.proof} />
          </div>
        )
      }

      <!-- How this score is calculated -->
      <div class="mt-8 pt-6 border-t border-surface-variant/40" data-detail-tier="calc">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
          <div>
            <h4 class="text-[11px] font-black uppercase tracking-widest text-on-surface-variant mb-1.5 flex items-center gap-1">
              How this score is calculated <InfoIcon size="xs" />
            </h4>
            <p class="text-sm text-on-surface-variant max-w-2xl">
              Evidence builds each subscore. Subscores then combine into the final {category.name} score.
            </p>
          </div>
          <a
            href="#"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-tertiary hover:text-primary-container transition shrink-0"
          >
            Learn more about our rating system
            <span class="material-symbols-outlined text-[13px]">open_in_new</span>
          </a>
        </div>

        <!-- Step 1: Evidence → Subscores -->
        <div class="mb-8">
          <div class="flex items-center gap-2 mb-4">
            <span class="flex items-center justify-center w-6 h-6 rounded-full bg-primary-container text-white text-[11px] font-black">1</span>
            <h5 class="text-sm font-bold text-on-surface">Evidence → Subscores</h5>
          </div>

          <div class="space-y-4">
            {
              evidenceBySubscore.map(({ sub, items, rawSubTotal }) => {
                const sv = getScoreVisual(sub.score);
                const parts = items.map((item) => item.contribution.toFixed(2)).join(' + ');
                return (
                  <div class="border border-surface-variant rounded-xl overflow-hidden bg-white">
                    <div class="px-4 py-3 bg-surface-container-low/70 border-b border-surface-variant flex items-center justify-between gap-3">
                      <span class="font-bold text-sm text-on-surface">{sub.name}</span>
                      <span class={`text-sm font-black tabular-nums ${sv.text}`}>{fmtScore(sub.score)}</span>
                    </div>
                    <div class="divide-y divide-surface-variant/50">
                      {
                        items.map((item) => {
                          const itemVisual = getScoreVisual(item.internal);
                          return (
                            <a
                              href={testContributorUrl(category.key, sub.name, item.label)}
                              class="px-4 py-2.5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 text-[12px] hover:bg-surface-container-low transition-colors group"
                            >
                              <span class="text-on-surface-variant group-hover:text-primary-container underline-offset-2 group-hover:underline">{item.label}</span>
                              <span class="tabular-nums text-on-surface-variant sm:text-right">
                                <span class={`font-bold ${itemVisual.text}`}>{fmtScore(item.internal)}</span>
                                <span class="text-tertiary mx-1.5">×</span>
                                <span>{item.weight}%</span>
                                <span class="text-tertiary mx-1.5">=</span>
                                <span class={`font-bold ${itemVisual.text}`}>{item.contribution.toFixed(2)}</span>
                              </span>
                            </a>
                          );
                        })
                      }
                    </div>
                    <div class={`px-4 py-2.5 text-[12px] tabular-nums ${sv.softBg} border-t ${sv.softBorder} grid grid-cols-1 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center gap-1 sm:gap-4`}>
                      <span class="text-on-surface-variant">
                        {parts} = <span class={`font-bold ${sv.text}`}>{rawSubTotal.toFixed(2)}</span>
                      </span>
                      <span class="font-bold text-on-surface sm:text-right whitespace-nowrap">
                        Rounded to {fmtScore(sub.score)}
                      </span>
                    </div>
                  </div>
                );
              })
            }
          </div>
        </div>

        <!-- Step 2: Subscores → Category -->
        <div>
          <div class="flex items-center gap-2 mb-4">
            <span class="flex items-center justify-center w-6 h-6 rounded-full bg-primary-container text-white text-[11px] font-black">2</span>
            <h5 class="text-sm font-bold text-on-surface">Subscores → {category.name} score</h5>
          </div>

          <div class="border border-surface-variant rounded-xl overflow-hidden bg-white">
            <div class="hidden md:grid md:grid-cols-[minmax(120px,1fr)_4.5rem_4.5rem_minmax(0,1.25fr)] md:gap-x-6 px-5 py-2 border-b border-surface-variant bg-surface-container-low/70 text-[10px] font-bold uppercase tracking-widest text-tertiary">
              <span>Subscore</span>
              <span class="text-center">Score</span>
              <span class="text-center">Weight</span>
              <span>Contribution</span>
            </div>

            {
              subscoreContributions.map((sub, i) => {
                const sv = getScoreVisual(sub.score);
                const contrib = sub.contribution.toFixed(2);
                return (
                  <div class={`px-4 md:px-5 py-3 md:py-3.5 ${i < subscoreContributions.length - 1 ? 'border-b border-surface-variant/50' : ''}`}>
                    <div class="hidden md:grid md:grid-cols-[minmax(120px,1fr)_4.5rem_4.5rem_minmax(0,1.25fr)] md:gap-x-6 md:items-center">
                      <p class="font-semibold text-sm text-on-surface">{sub.name}</p>
                      <div class="flex justify-center">
                        <span class={`inline-flex items-center justify-center w-10 h-7 rounded-md border font-bold text-xs tabular-nums ${sv.border} ${sv.text} bg-white`}>
                          {fmtScore(sub.score)}
                        </span>
                      </div>
                      <p class="text-center text-sm font-semibold text-on-surface tabular-nums">{sub.weight}%</p>
                      <p class="text-[13px] text-on-surface-variant tabular-nums">
                        {fmtScore(sub.score)} × {sub.weight}% ={' '}
                        <span class={`font-bold ${sv.text}`}>{contrib}</span>
                      </p>
                    </div>
                    <div class="md:hidden space-y-1.5">
                      <p class="font-semibold text-sm text-on-surface">{sub.name}</p>
                      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[12px] text-on-surface-variant tabular-nums">
                        <span>{fmtScore(sub.score)} × {sub.weight}% = <span class={`font-bold ${sv.text}`}>{contrib}</span></span>
                      </div>
                    </div>
                  </div>
                );
              })
            }

            <div class={`border-t ${visual.softBorder} ${visual.softBg}`}>
              <div class="hidden md:grid md:grid-cols-[minmax(120px,1fr)_4.5rem_4.5rem_minmax(0,1.25fr)] md:gap-x-6 md:items-center px-5 py-4">
                <p class="font-semibold text-sm text-on-surface">Final {category.name} Score</p>
                <span aria-hidden="true"></span>
                <span aria-hidden="true"></span>
                <p class="text-[13px] text-on-surface-variant tabular-nums">
                  {subscoreSumParts} = <span class={`font-bold ${visual.text}`}>{categoryRawTotal.toFixed(2)}</span>
                  <span class="text-tertiary mx-2">→</span>
                  <span class={`font-bold text-lg ${visual.text}`}>{fmtScore(category.score)}</span>
                </p>
              </div>
              <div class="md:hidden px-4 py-4 space-y-2">
                <p class="font-semibold text-sm text-on-surface">Final {category.name} Score</p>
                <p class="text-[13px] text-on-surface-variant tabular-nums">
                  {subscoreSumParts} = <span class={`font-bold ${visual.text}`}>{categoryRawTotal.toFixed(2)}</span>
                  <span class="text-tertiary mx-2">→</span>
                  <span class={`font-bold text-lg ${visual.text}`}>{fmtScore(category.score)}</span>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- What this means -->
      <div class={`mt-6 ${visual.softBg} border ${visual.softBorder} rounded-xl p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4`} data-detail-tier="calc">
        <div class="flex items-center gap-4">
          <span class={`material-symbols-outlined text-3xl ${visual.text}`} style="font-variation-settings: 'FILL' 1;">
            check_circle
          </span>
          <div class="flex flex-col">
            <span class="font-bold text-on-surface">What this means</span>
            <p class={`text-[13px] ${visual.softText}`}>{category.whatThisMeans}</p>
          </div>
        </div>
        <div class={`flex flex-col items-center border-t sm:border-t-0 sm:border-l ${visual.softBorder} pt-3 sm:pt-0 sm:pl-8`}>
          <span class={`${visual.bg} text-[11px] font-black px-3 py-1 rounded uppercase mb-1`}>{visual.label}</span>
          <span class={`text-[11px] font-bold ${visual.text}`}>{visual.range}</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  [data-accordion-toggle][aria-expanded='true'] .accordion-icon {
    transform: rotate(180deg);
  }
  .accordion-icon {
    transition: transform 0.2s ease;
  }

  .subscore-card {
    cursor: pointer;
  }
  .subscore-card:hover {
    background-color: var(--color-surface-container-low, #f3f3f3);
  }
</style>

<script>
  function initSubscoreSelect() {
    document.querySelectorAll<HTMLElement>('[data-category]').forEach((categoryEl) => {
      if (categoryEl.dataset.subscoreBound === 'true') return;
      categoryEl.dataset.subscoreBound = 'true';

      const cards = Array.from(categoryEl.querySelectorAll<HTMLButtonElement>('[data-subscore-select]'));
      const panels = Array.from(categoryEl.querySelectorAll<HTMLElement>('[data-subscore-panel]'));
      if (!cards.length || !panels.length) return;

      function selectSubscore(index: string) {
        cards.forEach((card) => {
          const isActive = card.dataset.subscoreIndex === index;
          const activeBorder = card.dataset.activeBorder || 'border-green-600';

          card.setAttribute('aria-selected', isActive ? 'true' : 'false');
          card.classList.remove('border-surface-variant', 'border-green-600', 'border-orange-500', 'border-red-600');
          card.classList.add(isActive ? activeBorder : 'border-surface-variant');

          const badge = card.querySelector<HTMLElement>('[data-subscore-badge]');
          const label = card.querySelector<HTMLElement>('[data-subscore-label]');
          const chevron = card.querySelector<HTMLElement>('[data-subscore-chevron]');

          if (badge) {
            badge.classList.remove('border-surface-variant', 'border-green-600', 'border-orange-500', 'border-red-600', 'text-on-surface', 'text-on-surface/40');
            badge.classList.add(isActive ? activeBorder : 'border-surface-variant');
            badge.classList.add(isActive ? 'text-on-surface' : 'text-on-surface/40');
          }
          if (label) {
            label.classList.toggle('text-on-surface', isActive);
            label.classList.toggle('text-on-surface/50', !isActive);
          }
          if (chevron) {
            chevron.classList.remove('text-green-600', 'text-orange-500', 'text-red-600', 'text-tertiary/40');
            chevron.classList.add(isActive ? activeBorder.replace('border-', 'text-') : 'text-tertiary/40');
          }
        });

        panels.forEach((panel) => {
          panel.classList.toggle('hidden', panel.dataset.subscoreIndex !== index);
        });
      }

      cards.forEach((card) => {
        card.addEventListener('click', () => {
          const index = card.dataset.subscoreIndex;
          if (index !== undefined) selectSubscore(index);
        });
      });
    });
  }

  initSubscoreSelect();
  document.addEventListener('astro:page-load', initSubscoreSelect);
</script>
