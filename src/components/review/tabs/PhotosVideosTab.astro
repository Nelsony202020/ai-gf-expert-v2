---
import type { Product } from '../../../data/products';
import type { FeaturedReviewVideo, MediaItem } from '../../../data/aura-ai-media';
import { auraAiFeaturedVideo, auraAiMediaGallery } from '../../../data/aura-ai-media';
import BrandIcon from '../../ui/BrandIcon.astro';
import AgeRatingIcon from '../../ui/AgeRatingIcon.astro';
import NsfwAgeGateModal from '../NsfwAgeGateModal.astro';
import { brandIcons } from '../../../lib/brand-icons';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const featuredVideo: FeaturedReviewVideo = product.videoReview
  ? {
      youtubeId: product.videoReview.embedUrl.split('/embed/')[1]?.split('?')[0] ?? auraAiFeaturedVideo.youtubeId,
      title: `${product.name} review video`,
      description: `My complete hands-on review of ${product.name} — chat, characters, images, video, and more.`,
    }
  : auraAiFeaturedVideo;

const mediaItems: MediaItem[] = [
  ...auraAiMediaGallery,
  ...product.gallery.map((g, i) => ({
    id: `product-gallery-${i}`,
    type: 'image' as const,
    src: g.full,
    thumb: g.thumb,
    alt: g.alt,
    caption: g.alt,
    filter: 'gallery' as const,
  })),
];

const filters = [
  { id: 'all', label: 'All media', icon: 'grid_view' },
  { id: 'proof', label: 'Proof', icon: 'fact_check' },
  { id: 'videos', label: 'Videos', icon: 'videocam' },
  { id: 'characters', label: 'Characters', icon: 'groups' },
  { id: 'chat', label: 'Chat', icon: 'chat_bubble' },
  { id: 'image-generator', label: 'Image generator', icon: 'photo_library' },
];

const youtubeWatchUrl = `https://www.youtube.com/watch?v=${featuredVideo.youtubeId}`;
---

<section class="bg-white py-12 md:py-14" data-media-gallery-root>
  <div class="section-container px-4 md:px-8">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6 mb-8">
      <div class="min-w-0">
        <h2 class="text-3xl md:text-4xl font-black text-on-surface mb-3">Photos &amp; Videos</h2>
        <p class="text-on-surface-variant text-base md:text-lg max-w-2xl">
          Screenshots, test proof, and video from our {product.name} review — including media we captured during ratings tests.
        </p>
      </div>

      <div class="media-nsfw-box shrink-0">
        <div class="media-nsfw-toggle" role="group" aria-label="Content safety mode">
          <button
            type="button"
            class="media-nsfw-btn media-nsfw-btn--safe media-nsfw-btn--active"
            data-nsfw-mode="safe"
            aria-pressed="true"
            aria-label="Safe only"
          >
            <span class="material-symbols-outlined media-nsfw-btn__icon text-[22px]" aria-hidden="true">shield</span>
            <span class="media-nsfw-btn__label">Safe only</span>
          </button>
          <button
            type="button"
            class="media-nsfw-btn media-nsfw-btn--nsfw"
            data-nsfw-mode="nsfw"
            aria-pressed="false"
            aria-label="Show 18 plus content"
          >
            <AgeRatingIcon size={22} class="media-nsfw-btn__icon" />
            <span class="media-nsfw-btn__label">18+</span>
          </button>
        </div>
        <p class="media-nsfw-status" data-nsfw-status>
          <span class="material-symbols-outlined text-[14px]">lock</span>
          <span data-nsfw-status-text>18+ content is hidden</span>
        </p>
      </div>
    </div>

    <div class="flex flex-wrap gap-2 mb-8" data-media-filters role="tablist" aria-label="Media filters">
      {
        filters.map((f, i) => (
          <button
            type="button"
            role="tab"
            data-media-filter={f.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            class="media-filter-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold border border-surface-variant transition-colors"
          >
            <span class="material-symbols-outlined text-[15px]">{f.icon}</span>
            {f.label}
          </button>
        ))
      }
    </div>

    <div class="media-featured-box rounded-2xl border border-surface-variant overflow-hidden shadow-sm mb-8">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)]">
        <div class="relative aspect-video bg-black">
          <iframe
            src={`https://www.youtube.com/embed/${featuredVideo.youtubeId}`}
            title={featuredVideo.title}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            loading="lazy"
            class="absolute inset-0 w-full h-full border-0"
          />
        </div>
        <div class="p-5 md:p-6 flex flex-col justify-center bg-white">
          <div class="flex items-center gap-2.5 mb-3">
            <BrandIcon
              src={brandIcons.youtube.dark}
              srcLight={brandIcons.youtube.light}
              width={44}
              height={44}
              class="shrink-0"
            />
            <span class="text-[11px] font-black uppercase tracking-widest text-accent">Featured video review</span>
          </div>
          <h3 class="text-xl font-black text-on-surface mb-2">{product.name} review video</h3>
          <p class="text-sm text-on-surface-variant leading-relaxed mb-5">{featuredVideo.description}</p>
          <a
            href={youtubeWatchUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 self-start px-4 py-2.5 rounded-full border border-surface-variant bg-white text-sm font-bold text-on-surface hover:border-accent hover:text-accent transition-colors shadow-sm"
          >
            <svg class="w-[22px] h-[22px] shrink-0" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#FF0000" d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z" />
              <path fill="#FFF" d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
            Watch on YouTube
          </a>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3 md:gap-4" data-media-grid>
      {
        mediaItems.map((item) => (
          <figure
            class="media-card group relative rounded-xl overflow-hidden border border-surface-variant bg-surface-container-low aspect-[4/5]"
            data-media-item
            data-filter={item.filter}
            data-nsfw={item.nsfw ? 'true' : 'false'}
          >
            <img src={item.thumb} alt={item.alt} loading="lazy" class="media-card__img w-full h-full object-cover" />
            {
              item.type === 'video' && (
                <span class="absolute top-2 left-2 material-symbols-outlined text-white drop-shadow-md text-xl">play_circle</span>
              )
            }
            {
              item.nsfw && (
                <button type="button" class="media-card__nsfw absolute inset-0 flex flex-col items-center justify-center gap-2 bg-black/50 backdrop-blur-md text-white p-3 text-center">
                  <AgeRatingIcon size={40} />
                  <span class="text-[10px] font-black uppercase tracking-widest">18+ Preview</span>
                  <span class="text-xs font-bold">Tap to reveal</span>
                </button>
              )
            }
            <figcaption class="absolute inset-x-0 bottom-0 p-2.5 bg-gradient-to-t from-black/75 to-transparent pointer-events-none">
              <p class="text-[11px] font-bold text-white leading-tight">{item.caption}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p data-media-empty class="hidden text-center text-sm text-tertiary py-12">No media matches these filters.</p>
  </div>

  <NsfwAgeGateModal />
</section>

<style>
  .media-nsfw-box {
    border-radius: 14px;
    padding: 12px 14px 10px;
  }

  .media-nsfw-toggle {
    display: inline-flex;
    padding: 4px;
    border-radius: 999px;
    border: 1px solid var(--color-surface-variant);
    background: var(--color-surface-container-low);
    gap: 2px;
  }

  .media-nsfw-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-width: 96px;
    padding: 8px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 800;
    color: var(--color-on-surface-variant);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
  }

  .media-nsfw-btn__icon {
    flex-shrink: 0;
  }

  .media-nsfw-btn--safe.media-nsfw-btn--active {
    background: rgb(218 246 108 / 35%);
    color: #3d5a1e;
    box-shadow: inset 0 0 0 1px rgb(218 246 108 / 45%);
  }

  .media-nsfw-btn--nsfw.media-nsfw-btn--active {
    background: rgb(219 39 119 / 14%);
    color: var(--color-accent);
    box-shadow: inset 0 0 0 1px rgb(219 39 119 / 25%);
  }

  .media-nsfw-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 8px 0 0;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-tertiary);
  }

  .media-card[data-nsfw='true']:not(.media-card--revealed) .media-card__img {
    filter: blur(16px) brightness(0.6);
    transform: scale(1.06);
  }

  .media-card--revealed .media-card__nsfw {
    display: none;
  }

  .media-card--hidden {
    display: none;
  }
</style>

<style is:global>
  .media-nsfw-box {
    background: #fff;
    border: 1px solid var(--color-surface-variant);
    box-shadow: 0 1px 3px rgb(0 0 0 / 4%);
  }

  [data-theme='dark'] .media-nsfw-box {
    background: #1a1f18;
    border-color: #2a3328;
    box-shadow: none;
  }

  [data-theme='dark'] .media-nsfw-toggle {
    background: #121612;
    border-color: #2a3328;
  }

  [data-theme='dark'] .media-nsfw-btn {
    color: #b8c4b2;
  }

  [data-theme='dark'] .media-nsfw-btn--safe.media-nsfw-btn--active {
    background: rgb(218 246 108 / 18%);
    color: #daf66c;
    box-shadow: inset 0 0 0 1px rgb(218 246 108 / 30%);
  }

  [data-theme='dark'] .media-nsfw-btn--nsfw.media-nsfw-btn--active {
    background: rgb(219 39 119 / 18%);
    color: #f472b6;
  }

  .media-filter-btn[aria-selected='true'] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .media-filter-btn[aria-selected='false'] {
    background: #fff;
    border-color: var(--color-surface-variant);
    color: var(--color-on-surface-variant);
  }

  .media-filter-btn[aria-selected='false']:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  [data-theme='dark'] .media-filter-btn[aria-selected='false'] {
    background: #1a1f18;
    border-color: #2a3328;
    color: #b8c4b2;
  }

  [data-theme='dark'] .media-filter-btn[aria-selected='false']:hover {
    border-color: #f472b6;
    color: #f472b6;
    background: rgb(219 39 119 / 10%);
  }

  [data-theme='dark'] .media-filter-btn[aria-selected='true'] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  [data-theme='dark'] .media-featured-box > div > div.bg-white {
    background: #1a1f18 !important;
  }
</style>

<script>
  const NSFW_STORAGE_KEY = 'lr-nsfw-preference';
  const NSFW_COOKIE_KEY = 'lr_nsfw_preference';

  type NsfwMode = 'safe' | 'nsfw';

  function readStoredMode(): NsfwMode | null {
    try {
      const fromStorage = localStorage.getItem(NSFW_STORAGE_KEY);
      if (fromStorage === 'safe' || fromStorage === 'nsfw') return fromStorage;
    } catch {
      /* ignore */
    }

    const cookie = document.cookie
      .split('; ')
      .find((row) => row.startsWith(`${NSFW_COOKIE_KEY}=`));
    const value = cookie?.split('=')[1];
    return value === 'safe' || value === 'nsfw' ? value : null;
  }

  function saveStoredMode(mode: NsfwMode, remember: boolean) {
    if (!remember) {
      try {
        localStorage.removeItem(NSFW_STORAGE_KEY);
      } catch {
        /* ignore */
      }
      document.cookie = `${NSFW_COOKIE_KEY}=; path=/; max-age=0; SameSite=Lax`;
      return;
    }

    try {
      localStorage.setItem(NSFW_STORAGE_KEY, mode);
    } catch {
      /* ignore */
    }

    const maxAge = 60 * 60 * 24 * 365;
    document.cookie = `${NSFW_COOKIE_KEY}=${mode}; path=/; max-age=${maxAge}; SameSite=Lax`;
  }

  function initNsfwGateOnce(
    onConfirm: (remember: boolean) => void,
    onCancel: () => void,
  ) {
    const html = document.documentElement;
    if (html.dataset.nsfwGateBound === 'true') {
      (window as Window & { __setNsfwGateHandlers?: (c: (remember: boolean) => void, x: () => void) => void }).__setNsfwGateHandlers?.(
        onConfirm,
        onCancel,
      );
      return;
    }
    html.dataset.nsfwGateBound = 'true';

    const gate = document.querySelector<HTMLElement>('[data-nsfw-gate]');
    const gateBackdrop = document.querySelector<HTMLElement>('[data-nsfw-gate-backdrop]');
    const gateAge = document.querySelector<HTMLInputElement>('[data-nsfw-gate-age]');
    const gateRemember = document.querySelector<HTMLInputElement>('[data-nsfw-gate-remember]');
    const gateCancel = document.querySelector<HTMLButtonElement>('[data-nsfw-gate-cancel]');
    const gateConfirm = document.querySelector<HTMLButtonElement>('[data-nsfw-gate-confirm]');

    let confirmHandler = onConfirm;
    let cancelHandler = onCancel;

    function closeGate() {
      if (!gate) return;
      gate.classList.add('hidden');
      gate.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    gateAge?.addEventListener('change', () => {
      if (gateConfirm) gateConfirm.disabled = !gateAge.checked;
    });

    gateCancel?.addEventListener('click', () => {
      cancelHandler();
      closeGate();
    });

    gateBackdrop?.addEventListener('click', () => {
      cancelHandler();
      closeGate();
    });

    gateConfirm?.addEventListener('click', () => {
      if (!gateAge?.checked) return;
      confirmHandler(gateRemember?.checked ?? false);
      closeGate();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && gate && !gate.classList.contains('hidden')) {
        cancelHandler();
        closeGate();
      }
    });

    (window as Window & { __setNsfwGateHandlers?: (c: (remember: boolean) => void, x: () => void) => void }).__setNsfwGateHandlers = (
      c,
      x,
    ) => {
      confirmHandler = c;
      cancelHandler = x;
    };
  }

  function initMediaGallery() {
    const root = document.querySelector('[data-media-gallery-root]');
    if (!root || root.dataset.bound === 'true') return;
    root.dataset.bound = 'true';

    const items = Array.from(root.querySelectorAll<HTMLElement>('[data-media-item]'));
    const filterBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-media-filter]'));
    const nsfwBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-nsfw-mode]'));
    const statusText = root.querySelector<HTMLElement>('[data-nsfw-status-text]');
    const emptyEl = root.querySelector<HTMLElement>('[data-media-empty]');

    const gate = document.querySelector<HTMLElement>('[data-nsfw-gate]');
    const gateAge = document.querySelector<HTMLInputElement>('[data-nsfw-gate-age]');
    const gateConfirm = document.querySelector<HTMLButtonElement>('[data-nsfw-gate-confirm]');

    let activeFilter = 'all';
    let nsfwMode: NsfwMode = 'safe';
    let pendingRevealItem: HTMLElement | null = null;

    function updateToggleUi() {
      nsfwBtns.forEach((btn) => {
        const mode = btn.dataset.nsfwMode as NsfwMode;
        const active = mode === nsfwMode;
        btn.classList.toggle('media-nsfw-btn--active', active);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      if (statusText) {
        statusText.textContent =
          nsfwMode === 'safe' ? '18+ content is hidden' : '18+ content is visible';
      }
    }

    function revealNsfwItems(target?: HTMLElement | null) {
      if (target) {
        target.classList.add('media-card--revealed');
        return;
      }

      items.forEach((item) => {
        if (item.dataset.nsfw === 'true') item.classList.add('media-card--revealed');
      });
    }

    function hideNsfwItems() {
      items.forEach((item) => {
        if (item.dataset.nsfw === 'true') item.classList.remove('media-card--revealed');
      });
    }

    function setNsfwMode(mode: NsfwMode, remember = false) {
      nsfwMode = mode;
      updateToggleUi();

      if (mode === 'nsfw') {
        revealNsfwItems(pendingRevealItem);
        saveStoredMode('nsfw', remember);
      } else {
        hideNsfwItems();
        saveStoredMode('safe', remember);
      }

      pendingRevealItem = null;
      applyFilters();
    }

    function applyFilters() {
      let visible = 0;
      items.forEach((item) => {
        const filter = item.dataset.filter ?? '';
        const isNsfw = item.dataset.nsfw === 'true';
        const matchFilter = activeFilter === 'all' || filter === activeFilter;
        const show = matchFilter;
        item.classList.toggle('media-card--hidden', !show);
        if (show) visible += 1;
        if (isNsfw && nsfwMode === 'safe') item.classList.remove('media-card--revealed');
      });
      if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);
    }

    function resetGateForm() {
      if (gateAge) gateAge.checked = false;
      const gateRemember = document.querySelector<HTMLInputElement>('[data-nsfw-gate-remember]');
      if (gateRemember) gateRemember.checked = false;
      if (gateConfirm) gateConfirm.disabled = true;
    }

    function openGate(target: HTMLElement | null = null) {
      if (!gate) return;
      pendingRevealItem = target;
      resetGateForm();
      gate.classList.remove('hidden');
      gate.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      gateConfirm?.focus();
    }

    initNsfwGateOnce(
      (remember) => setNsfwMode('nsfw', remember),
      () => {
        pendingRevealItem = null;
      },
    );

    function requestNsfwAccess(target: HTMLElement | null = null) {
      if (nsfwMode === 'nsfw') {
        if (target) target.classList.add('media-card--revealed');
        return;
      }

      const remembered = readStoredMode();
      if (remembered === 'nsfw') {
        setNsfwMode('nsfw', true);
        if (target) target.classList.add('media-card--revealed');
        return;
      }

      openGate(target);
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeFilter = btn.dataset.mediaFilter ?? 'all';
        filterBtns.forEach((b) => b.setAttribute('aria-selected', b === btn ? 'true' : 'false'));
        applyFilters();
      });
    });

    nsfwBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = (btn.dataset.nsfwMode as NsfwMode) ?? 'safe';
        if (mode === nsfwMode) return;

        if (mode === 'safe') {
          const remember = readStoredMode() !== null;
          setNsfwMode('safe', remember);
          return;
        }

        requestNsfwAccess();
      });
    });

    items.forEach((item) => {
      if (item.dataset.nsfw !== 'true') return;

      const overlay = item.querySelector<HTMLButtonElement>('.media-card__nsfw');
      overlay?.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        requestNsfwAccess(item);
      });
    });

    const remembered = readStoredMode();
    if (remembered === 'nsfw') {
      nsfwMode = 'nsfw';
      updateToggleUi();
      revealNsfwItems();
    } else {
      updateToggleUi();
    }

    applyFilters();
  }

  initMediaGallery();
  document.addEventListener('astro:page-load', initMediaGallery);
</script>
