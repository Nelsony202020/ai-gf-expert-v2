---
import type { Product } from '../../../data/products';
import RatingCategory from './RatingCategory.astro';
import DetailLevelControl from '../DetailLevelControl.astro';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<section class="bg-white py-12 md:py-14" data-ratings-root data-detail-level="all-in">
  <div class="section-container px-4 md:px-8">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-10 md:mb-12">
      <h2 class="text-3xl md:text-4xl font-black text-on-surface">Ratings &amp; Specs</h2>
      <div class="text-xs font-bold text-tertiary uppercase tracking-widest flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">analytics</span>
        Quantitative {product.methodology}
      </div>
    </div>

    <DetailLevelControl />

    <div class="space-y-5 md:space-y-6" data-accordion-group>
      {product.categories.map((category, i) => <RatingCategory category={category} open={i === 0} />)}
    </div>
  </div>
</section>
