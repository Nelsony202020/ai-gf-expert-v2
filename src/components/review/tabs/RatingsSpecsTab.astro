---
import type { Product } from '../../../data/products';
import RatingCategory from './RatingCategory.astro';
import DetailLevelControl from '../DetailLevelControl.astro';
import RatingsChangelogCompact from '../RatingsChangelogCompact.astro';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<section class="bg-white py-12 md:py-14" data-ratings-root data-detail-level="all-in">
  <div class="section-container px-4 md:px-8">
    <div class="mb-6 md:mb-8">
      <h2 class="text-3xl md:text-4xl font-black text-on-surface">Ratings &amp; Specs</h2>
    </div>

    <RatingsChangelogCompact entries={product.ratingChangelog} />

    <DetailLevelControl />

    <div class="space-y-5 md:space-y-6" data-accordion-group>
      {product.categories.map((category, i) => (
        <RatingCategory category={category} productName={product.name} open={i === 0} />
      ))}
    </div>
  </div>
</section>
