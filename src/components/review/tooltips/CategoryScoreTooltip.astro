---
import type { RatingCategory } from '../../../data/products';
import { products } from '../../../data/products';
import { getScoreChipClass, fmtScore } from '../../../lib/scores';
import { buildAllScoreBins } from '../../../lib/score-distribution';
import TooltipActionLinks from './TooltipActionLinks.astro';
import InlineTestLink from './InlineTestLink.astro';
import ScoreDistributionChart from './ScoreDistributionChart.astro';
import { getCategoryBrandIcon, getCategoryBrandIconLight } from '../../../lib/category-brand-icons';
import BrandIcon from '../../ui/BrandIcon.astro';
import InfoIcon from '../../ui/InfoIcon.astro';

interface Props {
  category: RatingCategory;
  compact?: boolean;
  methodologyOnly?: boolean;
  /** Roundup compare table — site category average only, no single-app score */
  compareAverageOnly?: boolean;
  /** Multi-product compare table — methodology only, no scores vs site avg */
  compareMode?: boolean;
  /** Compare table — what it is, site avg, and score distribution only */
  compareTableOnly?: boolean;
  /** Roundup pages — link test pages from labels instead of vial icons */
  inlineTestLinks?: boolean;
}

const {
  category,
  compact = false,
  methodologyOnly = false,
  compareAverageOnly = false,
  compareMode = false,
  compareTableOnly = false,
  inlineTestLinks = false,
} = Astro.props;
const tooltipId = `cat-${category.key}${compact ? '-compact' : ''}${compareAverageOnly ? '-compare' : ''}${compareMode ? '-compare-mode' : ''}${compareTableOnly ? '-compare-table' : ''}${inlineTestLinks ? '-inline' : ''}`;
const hideSiteAverage = compareAverageOnly || compareMode;
const hideScoreBlock = compareAverageOnly || compareTableOnly;
const linksMethodologyOnly = methodologyOnly || compareMode;

const currentScore = category.score;
const currentChip = getScoreChipClass(currentScore);

const scorePoints = products
  .map((p) => {
    const cat = p.categories.find((c) => c.key === category.key);
    return cat ? { slug: p.slug, name: p.name, score: cat.score } : null;
  })
  .filter((x): x is { slug: string; name: string; score: number } => !!x);

const avgScore = scorePoints.length
  ? scorePoints.reduce((s, x) => s + x.score, 0) / scorePoints.length
  : currentScore;

const bins = buildAllScoreBins(scorePoints);
const brandIcon = getCategoryBrandIcon(category.key);
const brandIconLight = getCategoryBrandIconLight(category.key);
const useDarkBrandIconOnly = category.key === 'customization' || category.key === 'chat';
---

<span
  role="button"
  tabindex="0"
  class="rt-tooltip-trigger inline-flex cursor-help shrink-0"
  data-ratings-tooltip-trigger={tooltipId}
  aria-label={compareTableOnly ? `About ${category.name}` : compareMode ? `About ${category.name}` : compareAverageOnly ? `About ${category.name} category average` : `About ${category.name} score`}
>
  <slot>
    <InfoIcon size="xs" class="text-tertiary/45 hover:text-tertiary/70" />
  </slot>
</span>

<template id={`tooltip-${tooltipId}`}>
  <div class={`ratings-tooltip-panel ${compact ? 'ratings-tooltip-panel--compact ratings-tooltip-panel--category' : ''}${compareAverageOnly || compareTableOnly ? ' ratings-tooltip-panel--compare-avg' : ''}`}>
    <div class="ratings-tooltip-panel__header">
      <div class="ratings-tooltip-panel__header-grid">
        <div class="ratings-tooltip-panel__what-block min-w-0">
          <p class="ratings-tooltip-panel__section-title">What it is</p>
          {
            compareTableOnly ? (
              <p class="ratings-tooltip-panel__desc">{category.description}</p>
            ) : (
              <div class="ratings-tooltip-panel__what-row">
                <p class="ratings-tooltip-panel__desc">{category.description}</p>
                {
                  brandIcon && (
                    <div class="ratings-tooltip-panel__brand-slot" aria-hidden="true">
                      {
                        useDarkBrandIconOnly ? (
                          <img
                            src={brandIcon}
                            alt=""
                            width="56"
                            height="56"
                            loading="lazy"
                            class="brand-icon brand-icon--dark brand-icon--always"
                          />
                        ) : brandIconLight ? (
                          <BrandIcon src={brandIcon} srcLight={brandIconLight} width={56} height={56} />
                        ) : (
                          <img src={brandIcon} alt="" width="56" height="56" loading="lazy" class={brandIcon.endsWith('.png') ? 'brand-icon' : ''} />
                        )
                      }
                    </div>
                  )
                }
              </div>
            )
          }
        </div>
        {
          compareTableOnly ? (
            <div class="ratings-tooltip-panel__score-block ratings-tooltip-panel__score-block--compare-avg">
              <p class="ratings-tooltip-panel__section-title">Avg</p>
              <p class="ratings-tooltip-panel__avg ratings-tooltip-panel__avg--solo tabular-nums">{fmtScore(avgScore)}</p>
            </div>
          ) : !hideScoreBlock && (
            compareAverageOnly ? (
              <div class="ratings-tooltip-panel__score-block ratings-tooltip-panel__score-block--compare-avg">
                <p class="ratings-tooltip-panel__section-title">Category avg</p>
                <p class="ratings-tooltip-panel__avg ratings-tooltip-panel__avg--solo tabular-nums">{fmtScore(avgScore)}</p>
              </div>
            ) : (
              <div class="ratings-tooltip-panel__score-block">
                <div class="ratings-tooltip-panel__score-row">
                  <span class={`rt-score-chip rt-score-chip--outline ${currentChip}`}>{fmtScore(currentScore)}</span>
                  {
                    inlineTestLinks ? (
                      <InlineTestLink categoryKey={category.key} class="ratings-tooltip-panel__score-label">
                        {category.name}
                      </InlineTestLink>
                    ) : (
                      <span class="ratings-tooltip-panel__score-label">{category.name}</span>
                    )
                  }
                </div>
                {
                  !hideSiteAverage && (
                    <p class="ratings-tooltip-panel__avg">
                      Avg: <span class="tabular-nums">{fmtScore(avgScore)}</span>
                    </p>
                  )
                }
              </div>
            )
          )
        }
      </div>
      {!compareTableOnly && !inlineTestLinks && <TooltipActionLinks categoryKey={category.key} methodologyOnly={linksMethodologyOnly} />}
    </div>

    {
      !compareTableOnly && (
        <div class="ratings-tooltip-panel__body">
          {
            !compareAverageOnly && (
              <div>
                <p class="ratings-tooltip-panel__section-title">Subscores</p>
                <div class="rt-comp-list">
                  {
                    category.subscores.map((sub) => {
                      const chip = getScoreChipClass(sub.score);
                      return (
                        <div class="rt-comp-row rt-comp-row--inline">
                          <div class="rt-comp-row__main">
                            <span class={`rt-score-chip rt-score-chip--outline rt-score-chip--xs ${chip}`}>{fmtScore(sub.score)}</span>
                            {
                              inlineTestLinks ? (
                                <InlineTestLink
                                  categoryKey={category.key}
                                  subscoreName={sub.name}
                                  class="rt-comp-name rt-comp-name--truncate"
                                >
                                  {sub.name}
                                </InlineTestLink>
                              ) : (
                                <>
                                  <InlineTestLink
                                    categoryKey={category.key}
                                    subscoreName={sub.name}
                                    class="rt-comp-name rt-comp-name--truncate"
                                  >
                                    {sub.name}
                                  </InlineTestLink>
                                  {
                                    !linksMethodologyOnly && (
                                      <TooltipActionLinks
                                        categoryKey={category.key}
                                        subscoreName={sub.name}
                                        compact
                                        resultsOnly
                                      />
                                    )
                                  }
                                </>
                              )
                            }
                          </div>
                        </div>
                      );
                    })
                  }
                </div>
              </div>
            )
          }

          <div>
            <p class="ratings-tooltip-panel__section-title">Score distribution</p>
            <ScoreDistributionChart bins={bins} />
          </div>
        </div>
      )
    }

    {
      compareTableOnly && (
        <div class="ratings-tooltip-panel__body ratings-tooltip-panel__body--compare-table">
          <div>
            <p class="ratings-tooltip-panel__section-title">Score distribution</p>
            <ScoreDistributionChart bins={bins} />
          </div>
        </div>
      )
    }
  </div>
</template>
