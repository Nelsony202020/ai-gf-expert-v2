---
import type { Subscore } from '../../../data/products';
import { products } from '../../../data/products';
import { equalWeights, fmtScore, getScoreChipClass, weightedValue } from '../../../lib/scores';
import { buildAllScoreBins } from '../../../lib/score-distribution';
import TooltipActionLinks from './TooltipActionLinks.astro';
import InlineTestLink from './InlineTestLink.astro';
import ScoreDistributionChart from './ScoreDistributionChart.astro';
import InfoIcon from '../../ui/InfoIcon.astro';

interface Props {
  categoryKey: string;
  categoryName: string;
  sub: Subscore;
  compact?: boolean;
  /** Multi-product compare table — methodology only, no scores vs site avg */
  compareMode?: boolean;
  /** Compare table — what it is and site avg only */
  compareTableOnly?: boolean;
  /** Roundup pages — link test pages from labels instead of vial icons */
  inlineTestLinks?: boolean;
}

const { categoryKey, categoryName, sub, compact = false, compareMode = false, compareTableOnly = false, inlineTestLinks = false } = Astro.props;
const tooltipId = `sub-${categoryKey}-${sub.name}${compact ? '-compact' : ''}${compareMode ? '-compare' : ''}${compareTableOnly ? '-compare-table' : ''}${inlineTestLinks ? '-inline' : ''}`.replace(/[^a-zA-Z0-9_-]/g, '-');

const currentScore = sub.score;
const currentChip = getScoreChipClass(currentScore);

const contributorWeights = equalWeights(sub.contributors.length);

const contributorPoints = sub.contributors.map((c, i) => {
  const internal = c.internalScore ?? sub.score;
  const weight = contributorWeights[i] ?? 0;
  const contribution = weightedValue(internal, weight);
  return { ...c, internal, weight, contribution };
});
const rawSubTotal = contributorPoints.reduce((s, x) => s + x.contribution, 0) || 1;

const scorePoints = products
  .map((p) => {
    const cat = p.categories.find((c) => c.key === categoryKey);
    const matchSub = cat?.subscores.find((s) => s.name === sub.name);
    return matchSub ? { slug: p.slug, name: p.name, score: matchSub.score } : null;
  })
  .filter((x): x is { slug: string; name: string; score: number } => !!x);

const avgScore = scorePoints.length
  ? scorePoints.reduce((s, x) => s + x.score, 0) / scorePoints.length
  : currentScore;

const bins = buildAllScoreBins(scorePoints);
---

<span
  role="button"
  tabindex="0"
  class="rt-tooltip-trigger inline-flex cursor-help shrink-0"
  data-ratings-tooltip-trigger={tooltipId}
  aria-label={`About ${sub.name} subscore`}
>
  <slot>
    <InfoIcon size="xs" class="text-tertiary/45 hover:text-tertiary/70" />
  </slot>
</span>

<template id={`tooltip-${tooltipId}`}>
  {
    compareTableOnly ? (
      <div class={`ratings-tooltip-panel ${compact ? 'ratings-tooltip-panel--compact' : ''} ratings-tooltip-panel--compare-avg`}>
        <div class="ratings-tooltip-panel__header">
          <div class="ratings-tooltip-panel__header-grid">
            <div class="min-w-0">
              <p class="ratings-tooltip-panel__section-title">What it is</p>
              <p class="ratings-tooltip-panel__desc">{sub.description}</p>
            </div>
            <div class="ratings-tooltip-panel__score-block ratings-tooltip-panel__score-block--compare-avg">
              <p class="ratings-tooltip-panel__section-title">Avg</p>
              <p class="ratings-tooltip-panel__avg ratings-tooltip-panel__avg--solo tabular-nums">{fmtScore(avgScore)}</p>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <div class={`ratings-tooltip-panel ${compact ? 'ratings-tooltip-panel--compact' : ''}`}>
    <div class="ratings-tooltip-panel__header">
      <div class="ratings-tooltip-panel__header-grid">
        <div class="min-w-0">
          <p class="ratings-tooltip-panel__section-title">What it is</p>
          <p class="ratings-tooltip-panel__desc">{sub.description}</p>
        </div>
        <div class="ratings-tooltip-panel__score-block">
          <div class="ratings-tooltip-panel__score-row">
            <span class={`rt-score-chip rt-score-chip--outline ${currentChip}`}>{fmtScore(currentScore)}</span>
            {
              inlineTestLinks ? (
                <InlineTestLink categoryKey={categoryKey} subscoreName={sub.name} class="ratings-tooltip-panel__score-label">
                  {sub.name}
                </InlineTestLink>
              ) : (
                <span class="ratings-tooltip-panel__score-label">{sub.name}</span>
              )
            }
          </div>
          {
            !compareMode && (
              <p class="ratings-tooltip-panel__avg">
                Avg: <span class="tabular-nums">{fmtScore(avgScore)}</span>
              </p>
            )
          }
        </div>
      </div>
      {!inlineTestLinks && <TooltipActionLinks categoryKey={categoryKey} subscoreName={sub.name} methodologyOnly={compareMode} />}
    </div>

    <div class="ratings-tooltip-panel__body">
      {!compact && (
        <>
          <div class="ratings-tooltip-panel__meta-block">
            <p class="ratings-tooltip-panel__meta-label">When it matters</p>
            <p class="ratings-tooltip-panel__meta-text">
              Higher {sub.name} usually means a more consistent experience in {categoryName}.
            </p>
          </div>
        </>
      )}

      {
        contributorPoints.length > 0 && (
          <div>
            <p class="ratings-tooltip-panel__section-title">Evidence</p>
            <div class="rt-comp-list">
              {
                contributorPoints.map((c) => {
                  const chip = getScoreChipClass(c.internal);
                  return (
                    <div class="rt-comp-row rt-comp-row--inline">
                      <div class="rt-comp-row__main">
                        <span class={`rt-score-chip rt-score-chip--outline rt-score-chip--xs ${chip}`}>{fmtScore(c.internal)}</span>
                        {
                          inlineTestLinks ? (
                            <InlineTestLink
                              categoryKey={categoryKey}
                              subscoreName={sub.name}
                              contributorLabel={c.label}
                              class="rt-comp-name rt-comp-name--truncate"
                            >
                              {c.label}
                            </InlineTestLink>
                          ) : (
                            <>
                              <InlineTestLink
                                categoryKey={categoryKey}
                                subscoreName={sub.name}
                                contributorLabel={c.label}
                                class="rt-comp-name rt-comp-name--truncate"
                              >
                                {c.label}
                              </InlineTestLink>
                              {
                                !compareMode && (
                                  <TooltipActionLinks
                                    categoryKey={categoryKey}
                                    subscoreName={sub.name}
                                    contributorLabel={c.label}
                                    compact
                                    resultsOnly
                                  />
                                )
                              }
                            </>
                          )
                        }
                      </div>
                    </div>
                  );
                })
              }
            </div>
          </div>
        )
      }

      <div>
        <p class="ratings-tooltip-panel__section-title">Score distribution</p>
        <ScoreDistributionChart bins={bins} />
      </div>
    </div>
  </div>
    )
  }
</template>
