---
import type { AuthorProfile } from '../../data/authors';
import VerifiedCheck from '../ui/VerifiedCheck.astro';
import SocialTooltip from '../ui/SocialTooltip.astro';

interface Props {
  author: AuthorProfile;
}

const { author } = Astro.props;
---

<div
  class="author-bio-popover hidden absolute z-50 top-full left-0 mt-2 w-[320px] md:w-[360px] rounded-xl border border-surface-variant bg-white shadow-xl p-5"
  data-author-bio-popover={author.slug}
  role="tooltip"
>
  <div class="flex items-start gap-3 mb-4">
    <img
      src={author.avatar}
      alt={author.name}
      class="w-14 h-14 rounded-full object-contain border-2 border-surface-variant shadow-sm shrink-0 bg-white p-0.5"
    />
    <div class="min-w-0">
      <div class="flex items-center gap-1">
        <p class="font-bold text-on-surface">{author.name}</p>
        <VerifiedCheck class="w-4 h-4" />
      </div>
      <p class="text-[11px] text-tertiary leading-snug mt-0.5">{author.title}</p>
    </div>
  </div>

  <p class="text-sm text-on-surface-variant leading-relaxed mb-4">{author.bio}</p>

  <SocialTooltip items={author.socials} variant="light" class="mb-5" />

  <a
    href={author.profileUrl}
    class="inline-flex items-center gap-1.5 text-sm font-bold text-accent hover:underline"
  >
    View full profile
    <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
  </a>
</div>

<script>
  function initAuthorBioPopovers() {
    document.querySelectorAll<HTMLElement>('[data-author-trigger]').forEach((trigger) => {
      if (trigger.dataset.bound === 'true') return;
      trigger.dataset.bound = 'true';

      const slug = trigger.dataset.authorTrigger;
      const popover = document.querySelector<HTMLElement>(`[data-author-bio-popover="${slug}"]`);
      if (!popover) return;

      let hideTimer: ReturnType<typeof setTimeout> | null = null;

      function show() {
        if (hideTimer) clearTimeout(hideTimer);
        popover!.classList.remove('hidden');
      }

      function hide() {
        hideTimer = setTimeout(() => popover!.classList.add('hidden'), 120);
      }

      trigger.addEventListener('mouseenter', show);
      trigger.addEventListener('mouseleave', hide);
      popover.addEventListener('mouseenter', show);
      popover.addEventListener('mouseleave', hide);
      trigger.addEventListener('focus', show);
      trigger.addEventListener('blur', hide);
    });
  }

  initAuthorBioPopovers();
  document.addEventListener('astro:page-load', initAuthorBioPopovers);
</script>
