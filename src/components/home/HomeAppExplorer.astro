---
import AppDirectory from '../directory/AppDirectory.astro';
import type { HomeExplorerApp } from '../../data/homepage';

interface Props {
  apps: HomeExplorerApp[];
}

/** Homepage wrapper — explorer stays on `/` (full directory also at `/apps`) */
const { apps } = Astro.props;
---

<AppDirectory
  apps={apps}
  basePath="/"
  showCardMetrics={false}
  title="Explore AI girlfriend apps"
  subtitle="Find the best AI companion apps based on our hands-on testing of 24+ platforms."
/>
