---
import InlineHelpTooltip from '../review/tooltips/InlineHelpTooltip.astro';

interface Props {
  type: 'card' | 'paypal' | 'crypto';
  tooltipId: string;
}

const { type, tooltipId } = Astro.props;

const config = {
  card: {
    label: 'Credit card payments available',
    title: 'Credit card payments',
    text: 'This app accepts credit or debit card payments for subscriptions and optional top-ups.',
  },
  paypal: {
    label: 'PayPal payments available',
    title: 'PayPal payments',
    text: 'This app accepts PayPal for subscriptions and optional top-ups.',
  },
  crypto: {
    label: 'Crypto payments available',
    title: 'Cryptocurrency payments',
    text: 'This app supports cryptocurrency payments for subscriptions or credits.',
  },
};
---

<InlineHelpTooltip
  id={tooltipId}
  title={config[type].title}
  label={config[type].label}
  text={config[type].text}
>
  <span class:list={['home-payment-icon', `home-payment-icon--${type}`]} aria-hidden="true">
    {
      type === 'card' ? (
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
          <rect x="2" y="5" width="20" height="14" rx="3" fill="#1e3a8a" />
          <rect x="2" y="9" width="20" height="3" fill="#172554" />
          <rect x="5" y="14.5" width="5" height="2" rx="1" fill="#fbbf24" />
          <rect x="11.5" y="14.5" width="3" height="2" rx="1" fill="#e5e7eb" />
        </svg>
      ) : type === 'paypal' ? (
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="4" fill="#003087" />
          <path d="M8.5 8.5h4.1c1.8 0 2.8 1 2.8 2.4 0 1.6-1.2 2.6-3.1 2.6H9.8L9.2 16H7l1.5-7.5z" fill="#fff" />
          <path d="M14.8 8.5H18c1.8 0 2.7 1 2.7 2.4 0 1.6-1.1 2.6-2.9 2.6h-2.1l-.6 2.5h-2.2l1.5-7.5z" fill="#009cde" opacity="0.95" />
        </svg>
      ) : (
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="10" fill="#f7931a" />
          <path
            d="M10.2 6.2h3.6c1.9 0 3.1 1 3.1 2.4 0 1.2-.8 2-2.2 2.3 1.6.2 2.6 1.2 2.6 2.7 0 1.8-1.4 3-3.8 3h-4.5V6.2zm1.6 3.9h1.9c.9 0 1.4-.4 1.4-1.1 0-.7-.5-1.1-1.5-1.1h-1.8v2.2zm0 4.8h2.2c1 0 1.6-.4 1.6-1.2 0-.8-.6-1.2-1.7-1.2h-2.1v2.4z"
            fill="#fff"
          />
        </svg>
      )
    }
  </span>
</InlineHelpTooltip>
