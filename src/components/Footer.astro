---
// NOTE: Site footer — dark brand background, social links, dark mode toggle.
import { authors } from '../data/authors';
import SocialTooltip from './ui/SocialTooltip.astro';
import ThemeToggle from './ui/ThemeToggle.astro';

const herman = authors['herman-carter'];
const year = new Date().getFullYear();

const columns = [
  {
    title: 'Reviews & Advice',
    links: [
      { label: 'AI Girlfriends', href: '#' },
      { label: 'AI Companions', href: '#' },
      { label: 'NSFW Apps', href: '#' },
      { label: 'Character Chatbots', href: '#' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Best-Of Roundups', href: '#' },
      { label: 'Buying Guides', href: '#' },
      { label: 'Our Methodology', href: '#' },
      { label: 'FAQ', href: '/faq' },
      { label: 'Affiliate Disclosure', href: '/legal/affiliate-disclosure' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About Us', href: '#' },
      { label: 'Contact', href: '/contact' },
      { label: 'HTML Sitemap', href: '/sitemap' },
    ],
  },
];
---

<footer class="site-footer">
  <div class="site-footer__accent" aria-hidden="true" />

  <div class="section-container px-4 md:px-8 relative z-[1]">
    <div class="site-footer__main">
      <div class="site-footer__brand">
        <a href="/" class="site-logo-link inline-block mb-5">
          <img
            src="/brand/ai-gf-logo-light.png"
            alt="AI Girlfriend Expert"
            class="site-footer__logo site-footer__logo--light h-14 md:h-16 w-auto object-contain"
            width="256"
            height="256"
            loading="lazy"
          />
          <img
            src="/brand/ai-gf-logo-white.png"
            alt="AI Girlfriend Expert"
            class="site-footer__logo site-footer__logo--dark h-14 md:h-16 w-auto object-contain hidden"
            width="240"
            height="76"
            loading="lazy"
          />
        </a>
        <p class="site-footer__tagline">
          Independent AI companion reviews — tested honestly, scored transparently, updated regularly.
        </p>
        {
          herman && (
            <div class="mt-6">
              <p class="site-footer__label">Follow us</p>
              <SocialTooltip items={herman.socials} variant="light" class="site-footer__socials" />
            </div>
          )
        }
      </div>

      {
        columns.map((col) => (
          <div class="site-footer__col">
            <h4 class="site-footer__label">{col.title}</h4>
            <ul class="site-footer__links">
              {col.links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="site-footer__bottom">
      <p>&copy; {year} Nelson Digital FZ LLC. All rights reserved.</p>
      <div class="site-footer__legal">
        <ThemeToggle variant="footer" />
        <a href="/legal/privacy">Privacy</a>
        <a href="/legal/terms">Terms</a>
        <a href="/legal/copyright">Copyright</a>
        <a href="/legal/disclaimer">Disclaimer</a>
        <a href="/faq">FAQ</a>
        <a href="/contact">Contact</a>
        <a href="/sitemap">Sitemap</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: #f4f7ef;
    color: #1a2418;
    padding: 3.5rem 0 2rem;
    overflow: hidden;
    border-top: 1px solid #e2e9dc;
  }

  .site-footer__logo--dark {
    display: none;
  }

  .site-footer__accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #daf66c, #db2777, #daf66c);
  }

  .site-footer__main {
    display: grid;
    grid-template-columns: 1.4fr repeat(3, 1fr);
    gap: 2.5rem 2rem;
  }

  @media (max-width: 900px) {
    .site-footer__main {
      grid-template-columns: 1fr 1fr;
    }

    .site-footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 520px) {
    .site-footer__main {
      grid-template-columns: 1fr;
    }
  }

  .site-footer__tagline {
    margin: 0;
    max-width: 280px;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: #5a6b52;
  }

  .site-footer__label {
    margin: 0 0 1rem;
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #3d5235;
  }

  .site-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .site-footer__links a {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #5a6b52;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .site-footer__links a:hover {
    color: #db2777;
  }

  .site-footer__bottom {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid #dde5d3;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.6875rem;
    color: #5a6b52;
  }

  .site-footer__legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
  }

  .site-footer__legal a,
  .theme-toggle--footer {
    color: #5a6b52;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.15s ease;
  }

  .site-footer__legal a:hover,
  .theme-toggle--footer:hover {
    color: #db2777;
  }
</style>

<style is:global>
  [data-theme='dark'] .site-footer__accent {
    background: linear-gradient(90deg, #daf66c, #db2777, #daf66c, #daf66c);
    background-size: 200% 100%;
    animation: footer-accent-slide 10s linear infinite;
  }

  @keyframes footer-accent-slide {
    0% { background-position: 0% 0; }
    100% { background-position: 200% 0; }
  }

  [data-theme='dark'] .site-footer {
    background: #1a2418;
    color: #ececec;
    border-top-color: transparent;
  }

  [data-theme='dark'] .site-footer__logo--light {
    display: none;
  }

  [data-theme='dark'] .site-footer__logo--dark {
    display: block;
  }

  [data-theme='dark'] .site-footer__tagline {
    color: #9cab96;
  }

  [data-theme='dark'] .site-footer__label {
    color: #daf66c;
  }

  [data-theme='dark'] .site-footer__links a {
    color: #9cab96;
  }

  [data-theme='dark'] .site-footer__links a:hover {
    color: #fff;
  }

  [data-theme='dark'] .site-footer__bottom {
    border-top-color: rgb(255 255 255 / 10%);
    color: #9cab96;
  }

  [data-theme='dark'] .site-footer__legal a,
  [data-theme='dark'] .theme-toggle--footer {
    color: #9cab96;
  }

  [data-theme='dark'] .site-footer__legal a:hover,
  [data-theme='dark'] .theme-toggle--footer:hover {
    color: #fff;
  }

  [data-theme='dark'] .site-footer__socials.social-tooltip--light .social-tooltip__link {
    background: rgb(255 255 255 / 8%);
    border-color: rgb(255 255 255 / 12%);
  }
</style>
