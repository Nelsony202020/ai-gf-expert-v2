---
interface Props {
  class?: string;
}

const { class: className = 'w-[18px] h-[18px]' } = Astro.props;
---

<span class={`inline-flex shrink-0 items-center justify-center leading-none overflow-visible ${className}`} aria-hidden="true">
  <svg
    viewBox="0 0 20 20"
    width="100%"
    height="100%"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Verified"
    class="block overflow-visible"
  >
    <circle cx="10" cy="10" r="9" fill="#DB2777" />
    <path
      d="M6.5 10.2 8.6 12.3 13.8 7.2"
      stroke="#fff"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
</span>
