---
interface Props {
  size?: number;
  class?: string;
}

const { size = 24, class: className = '' } = Astro.props;
---

<svg
  class={`age-rating-icon ${className}`.trim()}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <rect x="3" y="5" width="18" height="14" rx="3.5" stroke="currentColor" stroke-width="1.75" />
  <text
    x="12"
    y="15.25"
    text-anchor="middle"
    fill="currentColor"
    font-size="7.25"
    font-weight="800"
    font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
  >18+</text>
</svg>

<style>
  .age-rating-icon {
    display: block;
    flex-shrink: 0;
  }
</style>
