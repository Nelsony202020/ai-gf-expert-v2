---
import { products } from '../../data/products';
import { fmtScore, getScoreChipClass } from '../../lib/scores';
import { buildAllScoreBins } from '../../lib/score-distribution';
import ScoreDistributionChart from '../review/tooltips/ScoreDistributionChart.astro';

interface Props {
  variant: 'product' | 'category' | 'subscore';
  idPrefix: string;
}

const { variant, idPrefix } = Astro.props;

const product = products[0];
const chatCategory = product.categories.find((c) => c.key === 'chat')!;
const understanding = chatCategory.subscores.find((s) => s.name === 'Understanding')!;

const chatChip = getScoreChipClass(chatCategory.score);
const subChip = getScoreChipClass(understanding.score);

const scorePoints = products
  .map((p) => {
    const cat = p.categories.find((c) => c.key === 'chat');
    return cat ? { slug: p.slug, name: p.name, score: cat.score } : null;
  })
  .filter((x): x is { slug: string; name: string; score: number } => !!x);

const bins = buildAllScoreBins(scorePoints);
const embedClass = 'ratings-tooltip-panel--embed';

function partId(n: number) {
  return `${idPrefix}-part-${n}`;
}
---

<div class="test-tooltip-panel-demo">
  {
    variant === 'category' && (
      <div class={`ratings-tooltip-panel ${embedClass} ratings-tooltip-panel--compact ratings-tooltip-panel--category test-tooltip-demo__panel`}>
        <div class="ratings-tooltip-panel__header">
          <div class="ratings-tooltip-panel__header-grid">
            <div class="test-tooltip-callout-target ratings-tooltip-panel__score-block" id={partId(1)} data-callout="1">
              <div class="ratings-tooltip-panel__score-row">
                <span class={`rt-score-chip rt-score-chip--outline ${chatChip}`}>{fmtScore(chatCategory.score)}</span>
                <span class="ratings-tooltip-panel__score-label">Chat</span>
              </div>
            </div>
            <div class="test-tooltip-callout-target ratings-tooltip-panel__score-block" id={partId(2)} data-callout="2">
              <p class="ratings-tooltip-panel__avg ratings-tooltip-panel__avg--solo">
                Avg: <span class="tabular-nums">8.7</span>
              </p>
            </div>
          </div>
        </div>
        <div class="ratings-tooltip-panel__body">
          <div class="test-tooltip-callout-target" id={partId(3)} data-callout="3">
            <p class="ratings-tooltip-panel__section-title">Subscores</p>
            <div class="rt-comp-list">
              {
                chatCategory.subscores.map((sub) => {
                  const chip = getScoreChipClass(sub.score);
                  return (
                    <div class="rt-comp-row rt-comp-row--inline">
                      <div class="rt-comp-row__main">
                        <span class={`rt-score-chip rt-score-chip--outline rt-score-chip--xs ${chip}`}>{fmtScore(sub.score)}</span>
                        <span class="rt-comp-name rt-comp-name--truncate">{sub.name}</span>
                      </div>
                    </div>
                  );
                })
              }
            </div>
          </div>
          <div class="test-tooltip-callout-target" id={partId(4)} data-callout="4">
            <p class="ratings-tooltip-panel__section-title">Score distribution</p>
            <ScoreDistributionChart bins={bins} />
          </div>
        </div>
      </div>
    )
  }

  {
    variant === 'subscore' && (
      <div class={`ratings-tooltip-panel ${embedClass} ratings-tooltip-panel--compact test-tooltip-demo__panel`}>
        <div class="ratings-tooltip-panel__header">
          <div class="ratings-tooltip-panel__header-grid">
            <div class="test-tooltip-callout-target min-w-0" id={partId(1)} data-callout="1">
              <p class="ratings-tooltip-panel__section-title">What it is</p>
              <p class="ratings-tooltip-panel__desc">{understanding.description}</p>
            </div>
            <div class="test-tooltip-callout-target ratings-tooltip-panel__score-block" id={partId(2)} data-callout="2">
              <div class="ratings-tooltip-panel__score-row">
                <span class={`rt-score-chip rt-score-chip--outline ${subChip}`}>{fmtScore(understanding.score)}</span>
                <span class="ratings-tooltip-panel__score-label">Understanding</span>
              </div>
              <p class="ratings-tooltip-panel__avg">
                Avg: <span class="tabular-nums">8.4</span>
              </p>
            </div>
          </div>
        </div>
        <div class="ratings-tooltip-panel__body">
          <div class="test-tooltip-callout-target" id={partId(3)} data-callout="3">
            <p class="ratings-tooltip-panel__section-title">Evidence</p>
            <div class="rt-comp-list">
              {
                understanding.contributors.slice(0, 3).map((c) => {
                  const chip = getScoreChipClass(c.internalScore ?? understanding.score);
                  return (
                    <div class="rt-comp-row rt-comp-row--inline">
                      <div class="rt-comp-row__main">
                        <span class={`rt-score-chip rt-score-chip--outline rt-score-chip--xs ${chip}`}>{fmtScore(c.internalScore ?? understanding.score)}</span>
                        <span class="rt-comp-name rt-comp-name--truncate">{c.label}</span>
                      </div>
                    </div>
                  );
                })
              }
            </div>
          </div>
          <div class="test-tooltip-callout-target" id={partId(4)} data-callout="4">
            <p class="ratings-tooltip-panel__section-title">Score distribution</p>
            <ScoreDistributionChart bins={bins} />
          </div>
        </div>
      </div>
    )
  }

  {
    variant === 'product' && (
      <div class={`ratings-tooltip-panel ${embedClass} ratings-tooltip-panel--brand-card test-tooltip-demo__panel`}>
        <div class="home-brand-tip">
          <p class="test-tooltip-callout-target home-brand-tip__title" id={partId(1)} data-callout="1">
            <span>{product.name}</span>
          </p>
          <p class="home-brand-tip__liner">{product.overallSummary}</p>
          <div class="home-brand-tip__divider" aria-hidden="true"></div>
          <ul class="home-brand-tip__rows">
            <li class="test-tooltip-callout-target home-brand-tip__row" id={partId(2)} data-callout="2">
              <span class="home-brand-tip__icon home-brand-tip__icon--best" aria-hidden="true">
                <span class="material-symbols-outlined">group</span>
              </span>
              <div class="home-brand-tip__copy">
                <span class="home-brand-tip__label">Best for</span>
                <span class="home-brand-tip__value">Realistic chat and immersive media</span>
              </div>
            </li>
            <li class="test-tooltip-callout-target home-brand-tip__row" id={partId(3)} data-callout="3">
              <span class="home-brand-tip__icon home-brand-tip__icon--watch" aria-hidden="true">
                <span class="material-symbols-outlined">warning</span>
              </span>
              <div class="home-brand-tip__copy">
                <span class="home-brand-tip__label">Watch out for</span>
                <span class="home-brand-tip__value">Image generation can be slower than top rivals</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    )
  }
</div>
