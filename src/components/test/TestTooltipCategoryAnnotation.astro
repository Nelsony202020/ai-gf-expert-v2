---
import { products } from '../../data/products';
import CategoryScoreTooltipPanel from '../review/tooltips/CategoryScoreTooltipPanel.astro';
import TestTooltipAnnotation from './TestTooltipAnnotation.astro';
import { testTooltipsCategoryAnnotations } from '../../data/test-tooltips-content';

const product = products[0];
const chatCategory = product.categories.find((category) => category.key === 'chat')!;
---

<TestTooltipAnnotation
  idPrefix="category"
  ariaLabel="Category score tooltip annotated example"
  annotations={testTooltipsCategoryAnnotations}
  leftCallouts={[
    { n: 1, row: 'top' },
    { n: 3, row: 'bottom' },
  ]}
  rightCallouts={[
    { n: 2, row: 'top' },
    { n: 4, row: 'bottom' },
  ]}
  connectors={[
    { n: '1', side: 'left' },
    { n: '2', side: 'right' },
    { n: '3', side: 'left' },
    { n: '4', side: 'right' },
  ]}
  variant="wide"
>
  <CategoryScoreTooltipPanel category={chatCategory} embed annotate />
</TestTooltipAnnotation>
