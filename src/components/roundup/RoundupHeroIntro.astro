---
import type { Roundup } from '../../data/roundups/ai-girlfriend';
import { getAuthor } from '../../data/authors';
import AuthorBioPopover from '../review/AuthorBioPopover.astro';
import MethodologyTooltip from '../review/tooltips/MethodologyTooltip.astro';
import RatingsChangelogCompact from '../review/RatingsChangelogCompact.astro';
import InfoIcon from '../ui/InfoIcon.astro';
import VerifiedCheck from '../ui/VerifiedCheck.astro';
import ShareMenu from '../ui/ShareMenu.astro';

interface Props {
  roundup: Roundup;
  shareUrl?: string;
}

const { roundup, shareUrl } = Astro.props;
const monthYear = new Date().toLocaleString('en-US', { month: 'long', year: 'numeric' });
const shareTitle = `${roundup.title} (${monthYear}) — AI Girlfriend Expert`;
---

<div class="roundup-hero-intro">
  <nav class="text-[12px] font-medium text-tertiary mb-5 flex items-center gap-1.5 flex-wrap" aria-label="Breadcrumb">
    <a href="/" class="hover:text-accent transition-colors">Home</a>
    <span aria-hidden="true">›</span>
    <a href="/best/ai-girlfriend" class="hover:text-accent transition-colors">Roundups</a>
    <span aria-hidden="true">›</span>
    <span class="text-on-surface-variant">{roundup.title}</span>
  </nav>

  <div class="roundup-hero-intro__title-row">
    <h1 class="roundup-hero-intro__title text-3xl md:text-4xl lg:text-5xl font-black text-on-surface tracking-tight mb-0">
      <span class="roundup-hero-intro__title-main">{roundup.title}</span>
      <span class="roundup-hero-intro__title-date font-serif italic font-normal">{monthYear}</span>
    </h1>
    <ShareMenu shareTitle={shareTitle} shareUrl={shareUrl} variant="title-mobile" />
  </div>

  {roundup.changelog?.length > 0 && <RatingsChangelogCompact entries={roundup.changelog} />}

  <div class="article-meta-row mb-5">
    <span>Reviewed {roundup.reviewedDate}</span>
    <span class="article-meta-row__sep" aria-hidden="true">·</span>
    <span>Updated {roundup.modifiedDate}</span>
    <span class="article-meta-row__sep" aria-hidden="true">·</span>
    <span class="article-meta-row__methodology">
      {roundup.methodology}
      <MethodologyTooltip id={`roundup-methodology-${roundup.slug}`}>
        <InfoIcon size="xs" class="text-tertiary hover:text-accent" />
      </MethodologyTooltip>
    </span>
    <span class="article-meta-row__sep article-meta-row__sep--before-share" aria-hidden="true">·</span>
    <ShareMenu shareTitle={shareTitle} shareUrl={shareUrl} variant="inline" />
  </div>

  <div class="flex flex-wrap items-center gap-x-5 gap-y-3 border-b border-surface-variant pb-5 mb-5">
    {
      roundup.authors.map((author, i) => {
        const profile = author.slug ? getAuthor(author.slug) : undefined;
        return (
          <>
            {i > 0 && <div class="w-px h-10 bg-surface-variant hidden md:block" />}
            <div class={`flex items-center gap-2.5 ${profile ? 'relative' : ''}`}>
              <div class="w-9 h-9 rounded-full overflow-hidden border-2 border-white shadow-sm shrink-0 bg-white">
                <img alt={author.name} class="w-full h-full object-contain p-0.5" src={author.avatar} />
              </div>
              <div class="flex flex-col">
                {
                  profile ? (
                    <button
                      type="button"
                      class="flex items-center gap-1.5 text-left group overflow-visible"
                      data-author-trigger={author.slug}
                    >
                      <span class="text-sm font-bold group-hover:underline cursor-pointer">{author.name}</span>
                      {author.verified && <VerifiedCheck class="w-[16px] h-[16px] shrink-0" />}
                    </button>
                  ) : (
                    <div class="flex items-center gap-1.5">
                      <span class="text-sm font-bold">{author.name}</span>
                      {author.verified && <VerifiedCheck class="w-[16px] h-[16px] shrink-0" />}
                    </div>
                  )
                }
                <span class="text-[11px] text-tertiary font-medium">{author.role}</span>
              </div>
              {profile && <AuthorBioPopover author={profile} />}
            </div>
          </>
        );
      })
    }
  </div>

  <p class="text-[15px] md:text-base text-on-surface-variant leading-relaxed">
    {roundup.intro}
  </p>

  <button
    type="button"
    class="roundup-reading-trigger lg:hidden"
    data-reading-sheet-open
    aria-haspopup="dialog"
  >
    <span class="roundup-reading-trigger__label">Reading:</span>
    <span class="roundup-reading-trigger__value" data-mobile-reading-value>Skim</span>
    <span class="material-symbols-outlined roundup-reading-trigger__chevron" aria-hidden="true">expand_more</span>
  </button>
</div>
