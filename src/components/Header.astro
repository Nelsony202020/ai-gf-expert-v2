---
// NOTE: Placeholder header replicated from the mockups. Content/nav not final.
const navLinks = [
  { label: 'Reviews', href: '#' },
  { label: 'Roundups', href: '#' },
  { label: 'Guides', href: '#' },
];
---

<header class="border-b border-surface-variant sticky top-0 bg-white z-50">
  <div class="section-container h-16 flex items-center justify-between px-4 md:px-8">
    <div class="flex items-center gap-8">
      <a href="/" class="text-on-surface font-black text-2xl flex items-center shrink-0">
        <span class="text-primary font-extrabold text-3xl italic mr-1">LR</span>
        <span class="leading-none">
          <span class="block text-[10px] font-bold uppercase tracking-widest text-primary">Lovelace</span>
          <span class="block text-lg font-display">Reviews</span>
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-6 text-sm font-semibold text-on-surface">
        {
          navLinks.map((link) => (
            <a class="hover:text-primary-container transition-colors" href={link.href}>
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="hidden md:flex items-center">
        <div class="relative">
          <input
            class="pl-4 pr-10 py-1.5 border border-outline-variant rounded-full text-sm w-64 xl:w-80 focus:ring-1 focus:ring-primary-container focus:border-primary-container outline-none"
            placeholder="Search Reviews & More..."
            type="text"
          />
          <span class="material-symbols-outlined absolute right-3 top-1.5 text-[18px] text-tertiary">search</span>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-4 md:gap-6 text-sm font-semibold">
      <a class="hover:text-primary-container transition-colors" href="#">Sign In</a>
      <a
        class="bg-primary-container text-white px-5 py-2 rounded-full hover:opacity-90 transition shadow-sm"
        href="#">Join Now</a
      >
    </div>
  </div>
</header>
