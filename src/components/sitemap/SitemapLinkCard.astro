---
import type { HtmlSitemapLink } from '../../types/sitemap';

interface Props {
  title: string;
  count: number;
  icon: string;
  tone: 'amber' | 'lime' | 'green' | 'blue' | 'purple';
  links: HtmlSitemapLink[];
}

const { title, count, icon, tone, links } = Astro.props;
---

<section class="sitemap-card">
  <div class="sitemap-card__head">
    <span class={`sitemap-card__icon sitemap-card__icon--${tone}`}>
      <span class="material-symbols-outlined">{icon}</span>
    </span>
    <h2 class="sitemap-card__title">{title} ({count})</h2>
  </div>
  <ul class="sitemap-card__links">
    {
      links.map((link) => (
        <li>
          <a href={link.href} class="sitemap-card__link">
            <span>{link.label}</span>
            <span class="material-symbols-outlined sitemap-card__arrow">chevron_right</span>
          </a>
        </li>
      ))
    }
  </ul>
</section>
